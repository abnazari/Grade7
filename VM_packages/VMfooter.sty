%----------------------------------------------------------------------------------------
%   VMfooter.sty — Custom footer for ViewMath Grade 6 books
%   Left:  "Get Online" image + QR code + "Find more at" text
%   Right: ViewMath.com logo
%----------------------------------------------------------------------------------------
\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{VMfooter}[2026/03/02 ViewMath Grade 6 custom footer]

\RequirePackage{fancyhdr}
\RequirePackage{qrcode}
\RequirePackage{graphicx}
% Note: hyperref is NOT required here — it is loaded by the parent class.
% \href is available at shipout time when the footer is rendered.

%----------------------------------------------------------------------------------------
%   Configurable URL (defaults to grade 6)
%----------------------------------------------------------------------------------------
\newcommand{\vmQRURL}{https://viewmath.com/grade6}
\newcommand{\vmDisplayURL}{ViewMath.com/Grade6}

%----------------------------------------------------------------------------------------
%   Footer components
%----------------------------------------------------------------------------------------
\newcommand{\vmFooterLeft}{%
    \raisebox{0.9cm}{%
        \begin{minipage}[b]{0.55\textwidth}
            \begin{tabular}{@{}l@{}l@{}l@{}}
                \raisebox{-0.45cm}{\IfFileExists{get_online.pdf}{\includegraphics[height=1.1cm]{get_online.pdf}}{\makebox[1.1cm][c]{\textcolor{funBlue}{\fontsize{30}{30}\selectfont\faTablet}}}}\hspace*{0.1cm} &
                \raisebox{0cm}{\qrcode*[height=1.1cm]{\vmQRURL}} & \hspace{5pt}
                \begin{tabular}{@{}l@{}}
                    \raisebox{-0.1cm}[0pt][0pt]{\footnotesize\sffamily Find more at} \\
                    \raisebox{0cm}[0pt][0pt]{\href{\vmQRURL}{\footnotesize\sffamily\bfseries\vmDisplayURL}} \\[0cm]
                    \raisebox{0cm}{\textcolor{funBlue}{\faArrowRight}}
                \end{tabular}
            \end{tabular}
        \end{minipage}%
    }%
}

\newcommand{\vmFooterRight}{%
    \raisebox{0.55cm}{\IfFileExists{ViewMath.com.pdf}{\includegraphics[height=0.8cm]{ViewMath.com.pdf}}{\textbf{\textsf{\textcolor{funBlue}{\footnotesize ViewMath.com}}}}}%
}

%----------------------------------------------------------------------------------------
%   Apply footer to both regular and plain page styles
%----------------------------------------------------------------------------------------
\newcommand{\vmApplyFooter}{%
    \fancyfoot[L]{\vmFooterLeft}%
    \fancyfoot[R]{\vmFooterRight}%
    \fancypagestyle{plain}{%
        \fancyhead{}%
        \renewcommand{\headrulewidth}{0pt}%
        \fancyfoot[L]{\vmFooterLeft}%
        \fancyfoot[R]{\vmFooterRight}%
    }%
}
