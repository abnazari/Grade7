}

%========================================================================================
% 11. TWO-COLUMN COMPARISON
%     Side-by-side comparison box (e.g., "Sharing vs Grouping").
%     Usage:
%       \begin{compareBox}{Title Left}{Title Right}
%           Left content \tcblower Right content
%       \end{compareBox}
%========================================================================================
\newtcolorbox{compareBox}[3][funOrange]{
    enhanced,
    colback=#1!5,
    colframe=#1,
    colbacktitle=#1!15,
    coltitle=#1!80!black,
    fonttitle=\bfseries\sffamily,
    bicolor,
    colbacklower=#1!8,
    boxrule=1.5pt,
    arc=8pt,
    outer arc=8pt,
    sidebyside,
    sidebyside align=top,
    sidebyside gap=4mm,
    title={\begin{minipage}[t]{0.47\linewidth}\centering\textbf{#2}\end{minipage}\hfill%
           \begin{minipage}[t]{0.47\linewidth}\centering\textbf{#3}\end{minipage}},
    top=5mm, bottom=5mm,
    left=5mm, right=5mm,
    toptitle=3mm, bottomtitle=3mm,
    before skip=8pt,
    after skip=8pt,
}

