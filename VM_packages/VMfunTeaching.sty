%========================================================================================
% 16. FORMULA CARD
%     A prominent, centered formula reference card for key formulas.
%     Design: Bold border, large centered formula text, light background.
%     Usage: \formulaCard{Area of a Triangle}{$A = \frac{1}{2} \times b \times h$}
%========================================================================================
\newcommand{\formulaCard}[2]{%
    \par\vspace{4mm}%
    \begin{center}
    \begin{tcolorbox}[
        enhanced,
        colback=funGreen!6,
        colframe=funGreen,
        boxrule=2pt,
        arc=8pt,
        outer arc=8pt,
        width=0.78\linewidth,
        halign=center,
        top=5mm, bottom=5mm,
        left=8mm, right=8mm,
    ]
        {\sffamily\bfseries\color{funGreenDark}#1}\\[4mm]
        {\Large\color{funGreenDark}#2}
    \end{tcolorbox}
    \end{center}
    \vspace{2mm}%
}