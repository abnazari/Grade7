\ProvidesPackage{VMfunTeaching}[2026/03/02 Grade 7 Teaching Environments]

%========================================================================================
% 1. TOPIC TITLE BANNER
%    A large banner displayed at the top of each topic page.
%    Design: Light blue background with bold blue border, clean modern text.
%========================================================================================
\newcommand{\topicTitle}[1]{%
    \begin{center}
    \begin{tcolorbox}[
        enhanced,
        colback=funBlueLight,
        colframe=funBlue,
        coltitle=white,
        boxrule=2pt,
        arc=10pt,
        outer arc=10pt,
        top=5mm,
        bottom=5mm,
        left=8mm,
        right=8mm,
        width=0.85\linewidth,
        halign=center,
        fontupper=\Large\bfseries\sffamily\color{funBlueDark},
    ]
        #1%
    \end{tcolorbox}
    \end{center}
    \vspace{2mm}
}

%========================================================================================
% 2. CONCEPT BOX
%    Main teaching content box with colored header bar and light background.
%    Design: Colored title bar at top, light fill, rounded corners.
%    Usage: \begin{conceptBox}{Title} ... \end{conceptBox}
%    Optional color: \begin{conceptBox}[funTeal]{Title} ... \end{conceptBox}
%========================================================================================
\newtcolorbox{conceptBox}[2][funGreen]{
    enhanced,
    colback=#1!5,
    colframe=#1,
    colbacktitle=#1!15,
    coltitle=#1!80!black,
    fonttitle=\large\bfseries\sffamily,
    title={\raisebox{-0.1em}{\color{#1}\faGraduationCap}~~#2},
    arc=8pt,
    outer arc=8pt,
    boxrule=1.5pt,
    top=5mm,
    bottom=5mm,
    left=5mm,
    right=5mm,
    toptitle=3mm,
    bottomtitle=3mm,
    before skip=8pt,
    after skip=8pt,
    breakable,
}

%========================================================================================
% 3. SUBTITLE INSIDE BOXES
%    A styled subtitle for use inside concept boxes and other environments.
%    Usage: \boxSubtitle{Steps to Add}
%========================================================================================
\newcommand{\boxSubtitle}[2][funBlue]{%
    \par\vspace{3mm}%
    {\large\bfseries\sffamily\color{#1}#2}%
    \par\vspace{2mm}%
}

%========================================================================================
% 4. STEPS BOX (Step-by-step instructions)
%    A numbered sequence of steps inside a light blue box.
%    Design: Light blue background, numbered steps with colored circles.
%    Usage:
%      \begin{stepsBox}{Steps to Add}
%          \step Add the ones column
%          \step Add the tens column
%      \end{stepsBox}
%========================================================================================
\newcounter{funStepCounter}

\newtcolorbox{stepsBox}[2][funBlue]{
    enhanced,
    colback=#1!5,
    colframe=#1,
    colbacktitle=#1!15,
    coltitle=#1!80!black,
    fonttitle=\large\bfseries\sffamily,
    title={\raisebox{-0.1em}{\color{#1}\faListOl}~~#2},
    arc=8pt,
    outer arc=8pt,
    boxrule=1.5pt,
    top=5mm,
    bottom=5mm,
    left=5mm,
    right=5mm,
    toptitle=3mm,
    bottomtitle=3mm,
    before skip=8pt,
    after skip=8pt,
    before upper={\setcounter{funStepCounter}{0}},
    breakable,
}

%% Individual step command (auto-numbered with colored circles)
\newcommand{\funStep}{%
    \stepcounter{funStepCounter}%
    \par\vspace{3mm}\noindent
    \ifnum\value{funStepCounter}=1 \stepCircle{\thefunStepCounter}{stepOne}\fi
    \ifnum\value{funStepCounter}=2 \stepCircle{\thefunStepCounter}{stepTwo}\fi
    \ifnum\value{funStepCounter}=3 \stepCircle{\thefunStepCounter}{stepThree}\fi
    \ifnum\value{funStepCounter}=4 \stepCircle{\thefunStepCounter}{stepFour}\fi
    \ifnum\value{funStepCounter}=5 \stepCircle{\thefunStepCounter}{stepFive}\fi
    \ifnum\value{funStepCounter}>5 \stepCircle{\thefunStepCounter}{funBlue}\fi
    \hspace{3mm}%
}

%% Named step (manual number and color)
\newcommand{\namedStep}[2]{\par\vspace{3mm}\noindent\stepCircle{#1}{#2}\hspace{3mm}}

