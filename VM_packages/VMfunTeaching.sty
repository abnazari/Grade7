%% Individual vocabulary entry
%% Usage: \vocabWord{Dividend}{The number being divided.}
\newcommand{\vocabWord}[2]{%
    \par\noindent\textbf{\color{funTealDark}\sffamily #1} --- #2\par\vspace{2mm}%
}

