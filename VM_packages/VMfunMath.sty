%========================================================================================
% 18. MEASUREMENT RULER
%     Draws a ruler with inch or cm markings.
%     Usage: \ruler{6}{inches}  or  \ruler{15}{cm}
%========================================================================================
\newcommand{\ruler}[2]{%
    \begin{center}
    \begin{tikzpicture}
        % Ruler body
        \fill[funYellow!20, draw=funYellow!60, thick, rounded corners=2pt]
            (-0.3, -0.4) rectangle (#1 * 0.8 + 0.3, 0.6);
        % Markings
        \foreach \i in {0,...,#1} {
            \draw[thick] (\i * 0.8, -0.3) -- (\i * 0.8, 0.2);
            \node[below, font=\scriptsize\sffamily] at (\i * 0.8, -0.35) {\i};
        }
        % Label
        \node[above, font=\tiny\sffamily\color{funGrayDark}] at (#1 * 0.4, 0.55) {#2};
    \end{tikzpicture}%
    \end{center}%
}

%========================================================================================
% 19. VERTICAL BAR GRAPH
%     Draws a simple vertical bar chart for data/graph topics.
%     Usage: \barGraph{Favorite Fruits}{Apple/5,Banana/3,Orange/7,Grape/2}{8}
%     Optional color: \barGraph[funGreen]{Title}{data}{max}
%========================================================================================
\newcommand{\barGraph}[4][funBlue]{%
    \begin{center}
    \begin{tikzpicture}
        % Y-axis
        \draw[thick, funGrayDark] (0, 0) -- (0, {#4 * 0.55 + 0.3});
        \foreach \y in {0,...,#4} {
            \draw[funGray!50] (-0.08, {\y * 0.55}) -- (0.08, {\y * 0.55});
            \node[left, font=\scriptsize\sffamily] at (-0.12, {\y * 0.55}) {\y};
        }
        % Bars
        \foreach \lbl/\val [count=\i] in {#3} {
            \fill[#1!50, draw=#1, thick, rounded corners=1.5pt]
                ({\i * 1.1 - 0.8}, 0) rectangle ++(0.7, {\val * 0.55});
            \node[below, font=\scriptsize\sffamily, text width=1.2cm, align=center]
                at ({\i * 1.1 - 0.45}, -0.15) {\lbl};
            \node[above, font=\scriptsize\sffamily\bfseries, color=#1!80!black]
                at ({\i * 1.1 - 0.45}, {\val * 0.55 + 0.05}) {\val};
        }
    \end{tikzpicture}%
    \end{center}%
}

%========================================================================================
% 20. AREA GRID (unit squares for measuring area)
%     Draws a grid of unit squares for area counting (Ch 7).
%     More contiguous than arrayGrid — shows true unit-square tiling.
%     Usage: \areaGrid{3}{5}             % 3 rows × 5 columns
%     Optional color: \areaGrid[funGreen]{4}{6}
%========================================================================================
\newcommand{\areaGrid}[3][funBlue]{%
    \begin{center}
    \begin{tikzpicture}
        % Filled unit squares
        \foreach \r in {1,...,#2} {
            \foreach \c in {1,...,#3} {
                \fill[#1!12] ({(\c-1)*0.6}, {(#2-\r)*0.6}) rectangle ++(0.6, 0.6);
                \draw[#1!40, thin] ({(\c-1)*0.6}, {(#2-\r)*0.6}) rectangle ++(0.6, 0.6);
            }
        }
        % Thick outer border
        \draw[#1, thick] (0, 0) rectangle ({#3*0.6}, {#2*0.6});
        % "1 unit" bracket on top
        \draw[<->, #1!70, thick] (0, {#2*0.6 + 0.2}) -- (0.6, {#2*0.6 + 0.2});
        \node[above, font=\tiny\sffamily\color{#1!70}] at (0.3, {#2*0.6 + 0.2}) {1};
    \end{tikzpicture}%
    \end{center}%
}

%========================================================================================
% 21. PERIMETER RECTANGLE (with labeled sides)
%     Draws a rectangle with side lengths shown for perimeter problems.
%     Usage: \perimeterRect{8}{5}{cm}
%     Optional color: \perimeterRect[funGreen]{6}{3}{in}
%========================================================================================
\newcommand{\perimeterRect}[4][funBlue]{%
    \begin{center}
    \begin{tikzpicture}
        \pgfmathsetmacro{\w}{min(#2 * 0.5, 4)}
        \pgfmathsetmacro{\h}{min(#3 * 0.5, 3)}
        % Rectangle
        \draw[#1, thick, fill=#1!6, rounded corners=2pt] (0, 0) rectangle (\w, \h);
        % Side labels
        \node[below, font=\small\sffamily\bfseries\color{#1!80!black}]
            at ({\w/2}, -0.1) {#2 #4};
        \node[above, font=\small\sffamily\bfseries\color{#1!80!black}]
            at ({\w/2}, {\h + 0.1}) {#2 #4};
        \node[left, font=\small\sffamily\bfseries\color{#1!80!black}, rotate=90, anchor=south]
            at (-0.1, {\h/2}) {#3 #4};
        \node[right, font=\small\sffamily\bfseries\color{#1!80!black}, rotate=-90, anchor=south]
            at ({\w + 0.1}, {\h/2}) {#3 #4};
        % Corner dots
        \fill[#1] (0, 0) circle (2pt);
        \fill[#1] (\w, 0) circle (2pt);
        \fill[#1] (0, \h) circle (2pt);
        \fill[#1] (\w, \h) circle (2pt);
    \end{tikzpicture}%
    \end{center}%
}

%========================================================================================
% 22. SKIP COUNTING ARCS (number line with hop arcs)
%     Number line with colored arcs showing skip counting jumps.
%     Perfect for teaching multiplication as repeated addition.
%     Usage: \skipCountArc{0}{30}{5}     % skip count by 5 from 0 to 30
%     Optional color: \skipCountArc[funGreen]{0}{20}{4}
%========================================================================================
\newcommand{\skipCountArc}[4][funOrange]{%
    \begin{center}
    \begin{tikzpicture}
        \pgfmathtruncatemacro{\numJumps}{int((#3 - #2) / #4)}
        \pgfmathtruncatemacro{\lastJump}{\numJumps - 1}
        % Number line arrow
        \draw[->, thick, funGrayDark] (-0.3, 0) -- ({\numJumps * 1.2 + 0.5}, 0);
        % Tick marks and labels
        \foreach \j in {0,...,\numJumps} {
            \pgfmathtruncatemacro{\val}{#2 + \j * #4}
            \draw[thick] ({\j * 1.2}, -0.15) -- ({\j * 1.2}, 0.15);
            \node[below, font=\small\sffamily\bfseries] at ({\j * 1.2}, -0.25) {\val};
        }
        % Jump arcs with "+step" labels
        \ifnum\lastJump<0\else
        \foreach \j in {0,...,\lastJump} {
            \pgfmathsetmacro{\startX}{\j * 1.2 + 0.1}
            \pgfmathsetmacro{\endX}{(\j+1) * 1.2 - 0.1}
            \pgfmathsetmacro{\midX}{(\j * 1.2 + (\j+1) * 1.2) / 2}
            \draw[->, #1, thick]
                (\startX, 0.12) to[out=60, in=120] (\endX, 0.12);
            \node[above, font=\tiny\sffamily\bfseries\color{#1}]
                at (\midX, 0.55) {$+#4$};
        }
        \fi
    \end{tikzpicture}%
    \end{center}%
}

%========================================================================================
% 23. FRACTION NUMBER LINE
%     Number line from 0 to 1 divided into equal parts for fraction visualization.
%     Usage: \numberLineFraction{4}     % 0 to 1 divided into fourths
%     Optional color: \numberLineFraction[funGreen]{6}
%========================================================================================
\newcommand{\numberLineFraction}[2][funBlue]{%
    \begin{center}
    \begin{tikzpicture}
        \pgfmathsetmacro{\segW}{0.9}
        % Main line
        \draw[thick, funGrayDark] (-0.3, 0) -- ({#2 * \segW + 0.3}, 0);
        % Tick marks and labels
        \foreach \i in {0,...,#2} {
            \pgfmathsetmacro{\x}{\i * \segW}
            \pgfmathtruncatemacro{\isFirst}{\i == 0 ? 1 : 0}
            \pgfmathtruncatemacro{\isLast}{\i == #2 ? 1 : 0}
            \ifnum\isFirst=1
                \draw[thick] (\x, -0.2) -- (\x, 0.2);
                \node[below, font=\small\sffamily\bfseries] at (\x, -0.25) {$0$};
            \else
                \ifnum\isLast=1
                    \draw[thick] (\x, -0.2) -- (\x, 0.2);
                    \node[below, font=\small\sffamily\bfseries] at (\x, -0.25) {$1$};
                \else
                    \draw[#1!60] (\x, -0.15) -- (\x, 0.15);
                    \node[below, font=\scriptsize\sffamily\color{#1}] at (\x, -0.25) {$\frac{\i}{#2}$};
                \fi
            \fi
        }
    \end{tikzpicture}%
    \end{center}%
}
