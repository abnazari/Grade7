    \end{center}
    \vspace{4mm}%
}

%========================================================================================
% 21. PUZZLE ANSWER COLLECTION SYSTEM
%    Collects puzzle answers during compilation and prints them at the end of the book.
%    Nothing is displayed inline — answers appear only in the Puzzle Solutions chapter.
%
%    Usage in topic files:   \puzzleAnswer{The number is $463$ because ...}
%    Usage in main .tex:     \printPuzzleAnswers   (at the very end, before \end{document})
%========================================================================================

% --- Answer file handle ---
\newwrite\pzans@file
\immediate\openout\pzans@file=\jobname.pzans
\newif\ifpzans@collecting
\pzans@collectingtrue

% --- Puzzle counter (resets per section) ---
\newcounter{pzAnsNum}
\setcounter{pzAnsNum}{0}

% --- Track chapter / section changes ---
\def\pzans@lastch{}
\def\pzans@lastsec{}

% --- \puzzleAnswer{text}  — collects silently, displays nothing inline ---
\newcommand{\puzzleAnswer}[1]{%
    \ifpzans@collecting
        % Detect chapter change
        \edef\pzans@currch{\thechapter}%
        \ifx\pzans@currch\pzans@lastch\else
            \immediate\write\pzans@file{\string\pzAnsChap{\thechapter}}%
            \global\let\pzans@lastch\pzans@currch
        \fi
        % Detect section change (resets puzzle counter)
        \edef\pzans@currsec{\thesection}%
        \ifx\pzans@currsec\pzans@lastsec\else
            \immediate\write\pzans@file{\string\pzAnsSec{\thesection}}%
            \global\let\pzans@lastsec\pzans@currsec
            \setcounter{pzAnsNum}{0}%
        \fi
        % Increment puzzle number and write entry
        \stepcounter{pzAnsNum}%
        \immediate\write\pzans@file{%
            \string\pzAnsItem{\thepzAnsNum}{\unexpanded{#1}}%
        }%
    \fi
}

% --- Color cycling for section accents ---
\newcounter{pzans@seccolor}
\setcounter{pzans@seccolor}{0}
\newcommand{\pzans@secaccent}{%
    \ifcase\value{pzans@seccolor}%
        puzzlePurple%   0
    \or puzzleTeal%     1
    \or funBlue%        2
    \or funOrange%      3
    \or funPink%        4
    \or funGreen%       5
    \fi
}
\newcommand{\pzans@nextsec}{%
    \stepcounter{pzans@seccolor}%
    \ifnum\value{pzans@seccolor}>5 \setcounter{pzans@seccolor}{0}\fi
}

% --- Color cycling for answer number badges ---
\newcounter{pzans@numcolor}
\setcounter{pzans@numcolor}{0}
\newcommand{\pzans@badgecolor}{%
    \ifcase\value{pzans@numcolor}%
        puzzlePurple%   0
    \or puzzleTeal%     1
    \or funBlue%        2
    \or funOrange%      3
    \or funPink%        4
    \or funGreen%       5
    \fi
}
\newcommand{\pzans@nextbadge}{%
    \stepcounter{pzans@numcolor}%
    \ifnum\value{pzans@numcolor}>5 \setcounter{pzans@numcolor}{0}\fi
}

%========================================================================================
% 22. PRINT PUZZLE ANSWERS — Call once at the end of the book
%    Reads the .pzans file and renders all collected answers grouped by chapter/section.
%
%    Usage:  \printPuzzleAnswers
%========================================================================================
\newcommand{\printPuzzleAnswers}{%
    % Close the file so it can be read back
    \immediate\closeout\pzans@file
    \global\pzans@collectingfalse
    %
    % ===== Title =====
    \chapter*{Puzzle Solutions}
    \addcontentsline{toc}{chapter}{Puzzle Solutions}
    \markboth{Puzzle Solutions}{Puzzle Solutions}
    %
    % ===== Header banner =====
    \begin{center}
    \begin{tcolorbox}[
        enhanced,
        colback=puzzlePurpleLight,
        colframe=puzzlePurple!60,
        boxrule=2pt,
        arc=14pt,
        outer arc=14pt,
        width=0.92\linewidth,
        halign=center,
        top=6mm, bottom=6mm,
        shadow={2pt}{-2pt}{0pt}{funGray!40},
    ]
        {\fontsize{22}{26}\selectfont\bfseries\sffamily\color{puzzlePurple}%
            \faPuzzlePiece\hspace{4mm}Puzzle Solutions\hspace{4mm}\faPuzzlePiece%
        }\\[4mm]
        {\large\sffamily\color{funGrayDark}%
        Try each puzzle on your own first!\\[1mm]
        Then check here to see if you cracked it \faStar%
        }
    \end{tcolorbox}
    \end{center}
    \vspace{6mm}
    %
    % ===== Define rendering commands for .pzans entries =====
    %
    % --- CHAPTER HEADER ---
    \def\pzAnsChap##1{%
        \par\vspace{8mm}%
        \setcounter{pzans@seccolor}{0}%
        \noindent
        \begin{tcolorbox}[
            enhanced,
            colback=puzzlePurpleLight,
            colframe=puzzlePurple,
            boxrule=2pt,
            arc=8pt,
            outer arc=8pt,
            left=6mm, right=6mm,
            top=3.5mm, bottom=3.5mm,
        ]
            {\Large\bfseries\sffamily\color{puzzlePurple}%
                \faPuzzlePiece\hspace{4mm}Chapter~##1%
            }%
        \end{tcolorbox}%
        \vspace{1mm}%
    }%
    %
    % --- SECTION HEADER ---
    \def\pzAnsSec##1{%
        \par\vspace{5mm}%
        \setcounter{pzans@numcolor}{0}%
        \noindent
        \begin{tcolorbox}[
            enhanced,
            colback=\pzans@secaccent!10,
            colframe=\pzans@secaccent!50,
            boxrule=1pt,
            arc=6pt,
            outer arc=6pt,
            left=5mm, right=5mm,
            top=2.5mm, bottom=2.5mm,
        ]
            {\bfseries\sffamily\color{\pzans@secaccent!85!black}%
                \faKey\hspace{2mm}Section~##1%
            }%
        \end{tcolorbox}%
        \vspace{3mm}\noindent
        \pzans@nextsec
    }%
    %
    % --- ANSWER ITEM: puzzle number badge + solution text ---
    \def\pzAnsItem##1##2{%
        \par\noindent
        \begin{tcolorbox}[
            enhanced,
            colback=\pzans@badgecolor!4,
            colframe=\pzans@badgecolor!25,
            boxrule=0.6pt,
            arc=5pt,
            outer arc=5pt,
            left=4mm, right=4mm,
            top=2.5mm, bottom=2.5mm,
            before skip=2.5mm,
            after skip=2.5mm,
            breakable,
        ]
            \sffamily\small
            \tikz[baseline=-0.3ex]{%
                \node[circle, fill=\pzans@badgecolor!70, text=white,
                      inner sep=0pt, minimum size=7mm,
                      font=\small\bfseries\sffamily]{##1};%
            }\hspace{2.5mm}%
            {\color{funGrayDark}##2}%
        \end{tcolorbox}%
        \pzans@nextbadge
    }%
    %
    % ===== Read and render the collected answers =====
    \setlength{\parindent}{0pt}%
    \InputIfFileExists{\jobname.pzans}{}{%
        \textit{No puzzle answers found. Compile again to generate solutions.}%
    }%
    %
    % ===== Footer =====
    \par\vspace{8mm}%
    \begin{center}
        {\Large\color{puzzlePurple}\faPuzzlePiece}\\[2mm]
        {\large\sffamily\color{funGrayDark}\bfseries Puzzle solutions complete.}\\[1mm]
        {\sffamily\color{funGray} Review any puzzles you found challenging and try them again.}
    \end{center}
}
