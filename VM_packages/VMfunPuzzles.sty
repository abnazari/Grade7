%========================================================================================
% 11. NUMBER PYRAMID (TikZ)
%    Draws a pyramid where each cell = sum of two cells below it.
%    Cells can be numbers or "?" (blank for student to fill).
%    Usage: \numberPyramid{8,3,5,2,1,4}  (bottom row first, left to right, row by row up)
%           For a 4-base pyramid: provide 4+3+2+1 = 10 values
%           For a 3-base pyramid: provide 3+2+1 = 6 values
%    Use "?" for blank cells.
%
%    Simpler usage: \numberPyramidBase{base values}{filled cells above}
%    Example: \numberPyramidFromBase{5,3,8,2}  (auto-fills sums, shows ? for missing)
%========================================================================================
\newcommand{\numberPyramid}[2][]{%
    % #1 = optional comma-separated list of values to show (bottom-up, left-right)
    % #2 = base size (number of cells in bottom row)
    % We'll draw a generic pyramid grid. Content is provided by the caller using
    % \pyramidCell commands inside a tikzpicture.
    % This is the SIMPLE version: just draws the grid.
    \begin{center}
    \begin{tikzpicture}[
        cell/.style={
            draw=puzzlePurple, line width=1.2pt, rounded corners=3pt,
            minimum width=2.0cm, minimum height=1.2cm, font=\normalsize\bfseries\sffamily,
            fill=white,
        },
        blankcell/.style={
            cell, fill=puzzlePurpleLight,
        },
    ]
    \pgfmathtruncatemacro{\baseSize}{#2}
    \pgfmathtruncatemacro{\totalRows}{\baseSize}
    \foreach \row in {0,...,\the\numexpr\totalRows-1\relax} {
        \pgfmathtruncatemacro{\cellsInRow}{\baseSize - \row}
        \foreach \col in {1,...,\cellsInRow} {
            \pgfmathsetmacro{\xpos}{(\col - 1) * 2.0 + \row * 1.0}
            \pgfmathsetmacro{\ypos}{\row * 1.35}
            \node[cell] at (\xpos, \ypos) {};
        }
    }
    \end{tikzpicture}
    \end{center}
}

%% A more practical pyramid: manually place values
%% Usage inside tikzpicture:
%%   \pyramidCell{row}{col}{value}  where row 0 = bottom, col starts at 0
\newcommand{\pyramidCell}[4][puzzlePurple]{% #1=color, #2=row, #3=col, #4=value
    \pgfmathsetmacro{\xpos}{(#3) * 2.0 + (#2) * 1.0}%
    \pgfmathsetmacro{\ypos}{(#2) * 1.35}%
    \node[draw=#1, line width=1.2pt, rounded corners=3pt,
          minimum width=2.0cm, minimum height=1.2cm, font=\normalsize\bfseries\sffamily,
          fill=white] at (\xpos, \ypos) {#4};%
}

%% Blank pyramid cell (for student to fill)
\newcommand{\pyramidBlank}[3][puzzlePurple]{% #1=color, #2=row, #3=col
    \pgfmathsetmacro{\xpos}{(#3) * 2.0 + (#2) * 1.0}%
    \pgfmathsetmacro{\ypos}{(#2) * 1.35}%
    \node[draw=#1, line width=1.2pt, rounded corners=3pt,
          minimum width=2.0cm, minimum height=1.2cm, font=\normalsize\bfseries\sffamily,
          fill=puzzlePurpleLight] at (\xpos, \ypos) {?};%
}

%========================================================================================
% 12. MAGIC GRID (TikZ)
%    Draws an n x n magic square grid with a target sum displayed.
%    Usage: \magicGrid{3}{15}{values}
%    Values: comma-separated, row by row, left to right, top to bottom.
%    Use "?" for blank cells.
%========================================================================================
\newcommand{\magicGrid}[3]{% #1=size, #2=target sum, #3=comma-separated values
    \begin{center}
    \begin{tikzpicture}[
        mgcell/.style={
            draw=puzzlePurple, line width=1.2pt,
            minimum size=1.1cm, font=\large\bfseries\sffamily,
            fill=white, anchor=center,
        },
        blankmgcell/.style={
            mgcell, fill=puzzlePurpleLight,
        },
    ]
    % Target sum label
    \node[fill=puzzleGold, text=white, rounded corners=4pt, inner sep=3pt,
          font=\small\bfseries\sffamily]
        at ({(#1-1)*1.2/2}, {#1*1.2 + 0.4}) {Target Sum: #2};

    % Draw cells
    \pgfmathtruncatemacro{\gridSize}{#1}
    \pgfmathtruncatemacro{\lastIdx}{\gridSize - 1}
    \foreach \val [count=\idx from 0] in {#3} {
        \pgfmathtruncatemacro{\col}{mod(\idx, \gridSize)}
        \pgfmathtruncatemacro{\row}{\gridSize - 1 - int(\idx / \gridSize)}
        \pgfmathsetmacro{\xpos}{\col * 1.2}
        \pgfmathsetmacro{\ypos}{\row * 1.2}
        \ifnum\pdfstrcmp{\val}{?}=0
            \node[blankmgcell] at (\xpos, \ypos) {?};
        \else
            \node[mgcell] at (\xpos, \ypos) {\val};
        \fi
    }
    % Arrows indicating row/column sums
    \pgfmathsetmacro{\arrowX}{\gridSize * 1.2 - 0.2}
    \pgfmathsetmacro{\arrowY}{-0.8}
    \node[font=\footnotesize\sffamily\color{puzzlePurple}] at (\arrowX + 0.2, {(\gridSize-1)*1.2/2})
        {\rotatebox{-90}{$\longrightarrow$ each = #2}};
    \end{tikzpicture}
    \end{center}
}

%========================================================================================
% 13. PUZZLE CIRCLES (TikZ)
%    Displays numbers inside colored circles in a row.
%    Perfect for odd-one-out puzzles and classification.
%    Usage: \puzzleCircles{12,25,38,47,50}
%    Optional color: \puzzleCircles[funOrange]{...}
%========================================================================================
\newcommand{\puzzleCircles}[2][puzzlePurple]{%
    \begin{center}
    \begin{tikzpicture}
    \foreach \val [count=\idx from 0] in {#2} {
        \pgfmathsetmacro{\xpos}{\idx * 2.0}
        \node[circle, draw=#1, line width=1.5pt, fill=white,
              minimum size=1.3cm, font=\large\bfseries\sffamily]
            at (\xpos, 0) {\val};
    }
    \end{tikzpicture}
    \end{center}
}

%========================================================================================
% 14. NUMBER CROSS (TikZ)
%    Cross-shaped puzzle where center + arms must satisfy a condition.
%    Usage: \numberCross{center}{top}{right}{bottom}{left}
%    Use "?" for blank cells.
%========================================================================================
\newcommand{\numberCross}[6][puzzlePurple]{% #1=color, #2=center, #3=top, #4=right, #5=bottom, #6=left
    \begin{center}
    \begin{tikzpicture}[
        ncell/.style={
            draw=#1, line width=1.2pt, rounded corners=2pt,
            minimum size=1.1cm, font=\large\bfseries\sffamily,
            fill=white,
        },
    ]
        \node[ncell] (center) at (0,0) {#2};
        \node[ncell] (top)    at (0,1.3) {#3};
        \node[ncell] (right)  at (1.3,0) {#4};
        \node[ncell] (bottom) at (0,-1.3) {#5};
        \node[ncell] (left)   at (-1.3,0) {#6};
    \end{tikzpicture}
    \end{center}
}

%========================================================================================
% 15. TARGET RING (TikZ)
%    Bullseye target visual with a large target number in the center.
%    Usage: \targetRing{100}
%    Optional color: \targetRing[funRed]{50}
%========================================================================================
\newcommand{\targetRing}[2][funRed]{%
    \begin{center}
    \begin{tikzpicture}
        % Outer ring
        \fill[#1!20] (0,0) circle (1.6cm);
        % Middle ring
        \fill[white] (0,0) circle (1.2cm);
        % Inner ring
        \fill[#1!30] (0,0) circle (0.85cm);
        % Bullseye center
        \fill[#1] (0,0) circle (0.5cm);
        % Target number
        \node[font=\Large\bfseries\sffamily, text=white] at (0,0) {#2};
        % Ring borders
        \draw[#1, line width=1pt] (0,0) circle (1.6cm);
        \draw[#1, line width=0.5pt] (0,0) circle (1.2cm);
        \draw[#1, line width=0.5pt] (0,0) circle (0.85cm);
    \end{tikzpicture}
    \end{center}
}

