        top=4mm, bottom=4mm,
        left=5mm, right=5mm,
        fontupper=\large\bfseries\sffamily\color{puzzlePurple},
    ]
        \faPuzzlePiece~~Puzzles Complete~~\faCheck%
        \\[2mm]%
        {\normalsize\normalfont\sffamily\color{puzzlePurple!80} Nice work --- all puzzles finished.}
    \end{tcolorbox}
    \end{center}
    \vspace{4mm}%
}

%========================================================================================
% 19. DIGIT CARDS (inline visual for number building)
%    Draws individual digit cards side by side — great for place value puzzles.
%    Usage: \digitCard{3} \digitCard{7} \digitCard{5}
%========================================================================================
\newcommand{\digitCard}[2][puzzlePurple]{%
    \tikz[baseline=-0.3ex]{%
        \node[draw=#1, fill=#1!8, rounded corners=3pt, inner sep=3pt,
              font=\Large\bfseries\sffamily, minimum size=0.9cm, line width=1.2pt]{#2};%
    }\hspace{1mm}%
}

%========================================================================================
% 20. PUZZLE SEPARATOR (decorative divider between puzzles)
%    Usage: \puzzleSep
%========================================================================================
\newcommand{\puzzleSep}{%
    \par\vspace{4mm}%
    \begin{center}
        {\color{puzzlePurple!30}%
        \faPuzzlePiece\hspace{4mm}%
        \rule[0.3ex]{3cm}{0.8pt}\hspace{4mm}%
        \faPuzzlePiece\hspace{4mm}%
        \rule[0.3ex]{3cm}{0.8pt}\hspace{4mm}%
