% ============================================================================
% VMfunWorkbook.sty — Grade 7 Math Workbook Environments (v2)
% Design language: diamond motifs, shadow-lifted cards, double-rule
% headers, L-shaped chapter accents, double-bordered panels.
% UNIQUE to Grade 7. Completely different from:
%   Grade 6 (circles, dots, teal, single rules)
%   Grade 3–5 (stars, bold primary boxes, mascots)
% ============================================================================
\ProvidesPackage{VMfunWorkbook}[2026/03/06 Grade 7 Workbook Environments v2]

% ── Page Header ────────────────────────────────────────────────────────────
% Bold centered title + subtitle separated by a DOUBLE rule.
% Distinct from Grade 6's wbPageTitle (thin single teal line).
% Usage: \wbPageHeader{title}{subtitle}
\newcommand{\wbPageHeader}[2]{%
    \begin{center}
    {\fontsize{24}{28}\selectfont\bfseries\sffamily\color{black!85}#1}%
    \par\vspace{3mm}%
    {\color{funBlue!30}\rule{0.55\textwidth}{1.2pt}}%
    \par\vspace{1.5pt}%
    {\color{funBlue!18}\rule{0.42\textwidth}{0.5pt}}%
    \par\vspace{3mm}%
    {\normalsize\sffamily\color{black!50}#2}%
    \end{center}
    \vspace{5mm}%
}

% ── Showcard ───────────────────────────────────────────────────────────────
% Full-width card with thick TOP accent bar + drop shadow.
% Distinct from Grade 6's left-border wbFeatureCard.
% Usage: \wbShowcard{color}{icon-cmd}{title}{description}
\newcommand{\wbShowcard}[4]{%
    \begin{tcolorbox}[
        enhanced,
        colback=white,
        colframe=black!6,
        arc=2pt,
        boxrule=0.3pt,
        left=5mm, right=5mm, top=4mm, bottom=3mm,
        borderline north={3pt}{0pt}{#1},
        shadow={1.5mm}{-1.5mm}{0mm}{black!8},
    ]
        {\color{#1}\Large #2}\hspace{4mm}%
        {\bfseries\sffamily\color{black!85}#3}\par\vspace{2pt}%
        {\sffamily\small\color{black!55}#4}
    \end{tcolorbox}
    \vspace{3mm}%
}

% ── Diamond Step ───────────────────────────────────────────────────────────
% 45-degree rotated square badge with number + title + description.
% Distinct from Grade 6's circular wbPathStep.
% Usage: \wbDiamondStep{number}{color}{title}{description}
\newcommand{\wbDiamondStep}[4]{%
    \noindent
    \begin{minipage}[t]{0.12\textwidth}
        \centering\vspace{4pt}%
        \begin{tikzpicture}[baseline=-0.3ex]
            \node[rotate=45, fill=#2!10, draw=#2!35,
                  line width=0.8pt, minimum size=10mm, inner sep=0pt] (bg) {};
            \node[font=\bfseries\sffamily\Large, text=#2!75!black]
                at (bg.center) {#1};
        \end{tikzpicture}%
    \end{minipage}%
    \begin{minipage}[t]{0.85\textwidth}
        \vspace{0pt}%
        {\large\bfseries\sffamily\color{black!85}#3}\par\vspace{2pt}%
        {\sffamily\color{black!55}#4}
    \end{minipage}%
    \par\vspace{7mm}%
}

% ── Tab Stripe ─────────────────────────────────────────────────────────────
% Card with L-shaped accent (thick LEFT + thin TOP border).
% Distinct from Grade 6's top-only wbChapterPreview.
% Usage: \begin{wbTabStripe}{color} ... \end{wbTabStripe}
\newtcolorbox{wbTabStripe}[1]{
    enhanced,
    colback=#1!3,
    colframe=#1!10,
    arc=2pt,
    boxrule=0.3pt,
    left=6mm, right=4mm, top=3.5mm, bottom=2mm,
    borderline west={3.5pt}{0pt}{#1!50},
    borderline north={1.5pt}{0pt}{#1!20},
}

% ── Dash Box ───────────────────────────────────────────────────────────────
% Double-bordered accent panel: solid outer + dashed inner.
% Distinct from Grade 6's single solid-border wbInfoPanel.
% Usage: \begin{wbDashBox}{color} ... \end{wbDashBox}
\newtcolorbox{wbDashBox}[1]{
    enhanced,
    colback=#1!3,
    colframe=#1!20,
    arc=5pt,
    boxrule=0.6pt,
    borderline={0.6pt}{2.5pt}{#1!15, dashed},
    left=7mm, right=7mm, top=5mm, bottom=5mm,
}

% ── Diamond Track ──────────────────────────────────────────────────────────
% Progress row with diamond (rotated-square) badge.
% Distinct from Grade 6's circular wbProgressRow.
% Usage: \wbDiamondTrack{color}{chapter-num}{chapter-title}{topic-count}
\newcommand{\wbDiamondTrack}[4]{%
    \noindent
    \begin{minipage}[c]{0.08\textwidth}
        \centering
        \begin{tikzpicture}[baseline=-0.3ex]
            \node[rotate=45, fill=#1!10, draw=#1!30,
                  line width=0.5pt, minimum size=8mm, inner sep=0pt] (bg) {};
            \node[font=\bfseries\sffamily\small, text=black!70]
                at (bg.center) {#2};
        \end{tikzpicture}%
    \end{minipage}%
    \begin{minipage}[c]{0.60\textwidth}
        {\sffamily\bfseries\color{black!80}#3}
    \end{minipage}%
    \begin{minipage}[c]{0.27\textwidth}
        \centering
        \rule[-1pt]{2.5cm}{0.4pt}\;/\;\rule[-1pt]{1cm}{0.4pt}
    \end{minipage}%
    \par\vspace{1pt}%
    {\color{black!8}\hrule height 0.4pt}%
    \vspace{5pt}%
}

% ── Check Item ─────────────────────────────────────────────────────────────
% Supply checklist line with colored checkbox icon.
% Usage: \wbCheckItem{color}{name}{description}
\newcommand{\wbCheckItem}[3]{%
    {\color{#1}\faCheckSquare}\hspace{3mm}%
    \textbf{#2}\hspace{0.3em}---\hspace{0.3em}{\color{black!55}#3}\par
    \vspace{3pt}%
}

% ── Vocab Word ─────────────────────────────────────────────────────────────
% Term–definition line for vocabulary pages.
% Usage: \wbVocabWord{term}{definition}
\newcommand{\wbVocabWord}[2]{%
    \textbf{\color{funBlueDark}#1}\hspace{0.3em}---\hspace{0.3em}#2\par\vspace{2.5pt}%
}

\endinput
