%----------------------------------------------------------------------------------------
% STEP NUMBER CIRCLES (used in step-by-step teaching)
%----------------------------------------------------------------------------------------
\newcommand{\stepCircle}[2]{% #1=number, #2=color
    \tikz[baseline=-0.3ex]{%
        \node[circle, fill=#2, text=white, inner sep=3pt, font=\bfseries\sffamily, minimum size=0.6cm]{#1};%
    }%
}

% Pre-defined colored step numbers
\newcommand{\stepOne}{\stepCircle{1}{stepOne}}
\newcommand{\stepTwo}{\stepCircle{2}{stepTwo}}
\newcommand{\stepThree}{\stepCircle{3}{stepThree}}
\newcommand{\stepFour}{\stepCircle{4}{stepFour}}
\newcommand{\stepFive}{\stepCircle{5}{stepFive}}
