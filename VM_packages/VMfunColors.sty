%========================================================================================
%
%   ICON PLACEHOLDER SYSTEM
%
%   When icon PDFs are ready, place them in the icons/ directory.
%   Until then, TikZ fallbacks are rendered automatically.
%
%   FORMAT: All icons should be delivered as vector PDF files.
%   ARTBOARD: Each icon should have a square artboard with no extra padding.
%             The icon artwork should fill the artboard edge-to-edge.
%   STYLE: Clean, modern flat style. Consistent outlines (2-3pt stroke).
%          Bright, saturated colors. Friendly faces where applicable.
%          No gradients — use flat fills with occasional simple shading.
%   COLORS: Use the palette defined above (funBlue, funGreen, funOrange, etc.)
%           unless a specific color is noted in the icon brief below.
%
%========================================================================================
\newcommand{\funIcon}[3]{% #1=icon filename, #2=fallback TikZ, #3=height
    \IfFileExists{icons/#1}{%
        \includegraphics[height=#3]{icons/#1}%
    }{#2}%
}

%% ======================================================================================
%%   ICON BRIEFS FOR GRAPHIC DESIGNER
%%   Each entry describes: filename, display size, description, color notes, usage context.
%% ======================================================================================

%% ---- 1. STAR ICON ----
%% File:    icons/star-icon.pdf
%% Size:    Artboard 80x80pt.  Displayed at 0.5–0.7 cm height.
%% Desc:    Classic 5-pointed star. Slightly rounded tips for a friendly feel.
%%          Warm gold/yellow fill (#FFC107). Thin darker outline (#F57F17).
%%          Optional: subtle inner highlight (lighter yellow streak) for shininess.
%% Used in: Topic title banners (flanking the title text),
%%          math-rule headers, challenge headers, encouragement banners.
\newcommand{\iconStar}[1][0.5cm]{%
    \funIcon{star-icon.pdf}{%
        \raisebox{-0.1em}{\textcolor{funYellow}{\large\faStar}}%
    }{#1}%
}

%% ---- 2. PENCIL CHARACTER ----
%% File:    icons/pencil-character.pdf
%% Size:    Artboard 100x200pt.  Displayed at 1.0–1.4 cm height.
%% Desc:    Cartoon pencil character (simple eyes, small smile).
%%          Yellow body (#FFC107), pink eraser top (#E91E63), silver ferrule,
%%          sharpened wood tip with graphite point.
%%          One arm waving or giving a thumbs-up (stick-figure arm).
%%          Slightly tilted ~10 degrees clockwise for a dynamic pose.
%% Used in: Tip boxes — sits to the left of the tip speech bubble.
\newcommand{\iconPencil}[1][1.2cm]{%
    \funIcon{pencil-character.pdf}{%
        \raisebox{-0.1em}{\textcolor{funYellow}{\LARGE\faPen}}%
    }{#1}%
}

%% ---- 3. OWL MASCOT ----
%% File:    icons/owl-mascot.pdf
%% Size:    Artboard 150x180pt.  Displayed at 1.2–1.6 cm height.
%% Desc:    Friendly cartoon owl — the book's main mascot/guide character.
%%          Round body, big expressive eyes (white sclera, large black pupils
%%          with small white highlight dots), small orange triangular beak,
%%          two ear tufts on top. Wings folded at sides.
%%          Body color: purple tones (#9C27B0 body, #CE93D8 belly patch).
%%          Optionally holding a tiny book or pointer stick.
%%          Sitting on a small branch or standing upright — whichever looks cuter.
%%          IMPORTANT: This is the recurring mascot. Keep the design consistent
%%          so the same character is recognisable throughout the book.
%% Used in: "Mascot Says" speech bubbles — sits to the left of the bubble.
