            % In day mode, \ansSec is suppressed (days provide their own separators)
            \def\ansSec##1{}%
        \else
            \def\ansDay##1##2{}%  no-op in regular study guide mode
            % --- SECTION HEADER: accent-colored rounded strip ---
            \def\ansSec##1{%
                \ans@sg@flushexp
                \par\vspace{5mm}%
