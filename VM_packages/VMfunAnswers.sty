                enhanced,
                colback=funBlueLight,
                colframe=funBlue,
                boxrule=2pt,
                arc=8pt,
                outer arc=8pt,
                left=6mm, right=6mm,
                top=3.5mm, bottom=3.5mm,
            ]
                {\Large\bfseries\sffamily\color{funBlueDark}%
                    \ifans@daymode\faCalendarDay\else\faBookOpen\fi%
                    \hspace{4mm}Chapter~##1%
                }%
            \end{tcolorbox}%
            \vspace{1mm}%
        }%
        %
        % --- DAY HEADER (day mode): flush explanations, then render day separator ---
        \ifans@daymode
            \def\ansDay##1##2{%
                \ans@sg@flushexp
                \par\vspace{5mm}%
                \setcounter{ans@numcolor}{0}%
                \noindent
                \begin{tcolorbox}[
                    enhanced,
                    colback=\ans@secaccent!10,
                    colframe=\ans@secaccent!50,
                    boxrule=1pt,
                    arc=6pt,
                    outer arc=6pt,
                    left=5mm, right=5mm,
                    top=2.5mm, bottom=2.5mm,
