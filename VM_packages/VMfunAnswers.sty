                \noindent
                \begin{tcolorbox}[
                    enhanced,
                    colback=\ans@secaccent!10,
                    colframe=\ans@secaccent!50,
                    boxrule=1pt,
                    arc=6pt,
                    outer arc=6pt,
                    left=5mm, right=5mm,
                    top=2.5mm, bottom=2.5mm,
                ]
                    {\bfseries\sffamily\color{\ans@secaccent!85!black}%
                        \faChevronRight\hspace{2mm}Section~##1%
                    }%
                \end{tcolorbox}%
                \vspace{3mm}\noindent
                \ans@nextsec
            }%
        \fi
        %
        % --- ANSWER ITEM: inline chip with colored number circle ---
        \def\ansItem##1##2{%
            \noindent
            \penalty0\relax
            \tcbox[
                on line,
                colback=white,
                colframe=\ans@bubblecolor!35,
                boxrule=0.6pt,
                arc=5pt,
                outer arc=5pt,
                left=1mm, right=2.5mm,
                top=1.5mm, bottom=1.5mm,
                boxsep=0pt,
            ]{%
                \tikz[baseline=-0.3ex]{%
                    \node[circle, fill=\ans@bubblecolor!75, text=white,
                          inner sep=0pt, minimum size=7mm,
                          font=\small\bfseries\sffamily]{##1};%
                }\hspace{2mm}%
                {\sffamily ##2}%
            }%
            \hspace{1.5mm plus 3mm minus 0mm}%
            \ans@nextbubble
        }%
        %
        % --- EXPLANATION: buffer for rendering after section answers ---
        \def\ansExplain##1##2{%
            \g@addto@macro\ans@sg@explist{\ans@sg@renderexp{##1}{##2}}%
        }%
        %
        % --- QUIZ HEADER: not used in study guide / day mode ---
        \def\ansQuiz##1##2{}%
    \fi\fi
    %
    % ===== Read and render the collected answers =====
    % Increase vertical spacing between rows of chips and allow flexible wrapping
    \setlength{\lineskip}{5pt}%
    \setlength{\lineskiplimit}{5pt}%
    \setlength{\emergencystretch}{3em}% Allow mild stretch only
    \setlength{\parindent}{0pt}%
    \raggedright% Left-align chips — prevents wide gaps between boxes
    \tolerance=9999%
    \hbadness=10000%
    \input{\jobname.ans}%
    %
    % ===== Flush the last buffered explanations =====
    \ifans@practicetest
        \ans@flushexp
    \else\ifans@quiz
        \ans@quiz@flushexp
    \else
        \ans@sg@flushexp
    \fi\fi
    %
    \par\vspace{8mm}%
    %
    % ===== FOOTER =====
    \begin{center}
        {\Large\color{funBlue}\faCheckCircle}\\[2mm]
        {\large\sffamily\color{funGrayDark}\bfseries Well done checking your answers!}\\[1mm]
        {\sffamily\color{funGray} Keep practicing to strengthen your skills.}
    \end{center}
}
