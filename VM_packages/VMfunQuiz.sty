%========================================================================================
% 4. QUIZ QUESTION (\quizQ)
%    Auto-numbered question. Compact with clear numbering.
%    Each question gets a colored number badge and a separator line.
%
%    Usage:
%      \quizQ What is the value of $3$ in $382$? \quizBlank[2cm]
%      \answer{$300$}
%========================================================================================
\newcommand{\quizQ}{%
    \refstepcounter{quizQuestion}%
    \refstepcounter{funProblem}%
    \par\vspace{4mm}%
    \noindent
    \tikz[baseline=(num.base)]{%
        \node[
            circle,
            fill=quizIndigo,
            text=white,
            font=\sffamily\bfseries\small,
            inner sep=0pt,
            minimum size=6mm,
        ] (num) {\thequizQuestion};
    }%
    \hspace{2mm}%
    \sffamily%
}

%========================================================================================
% 5. QUIZ ANSWER BLANK
%    A clean underline for students to write their answer.
%
%    Usage: \quizBlank         (3cm default)
%    Usage: \quizBlank[5cm]    (custom width)
%========================================================================================
\newcommand{\quizBlank}[1][3cm]{%
    \rule[-2pt]{#1}{0.5pt}%
}

%========================================================================================
% 6. QUIZ WORK SPACE
%    Empty dotted/lined area for students to show their work.
%
%    Usage: \quizWorkSpace          (2cm default)
%    Usage: \quizWorkSpace[3cm]     (custom height)
%========================================================================================
\newcommand{\quizWorkSpace}[1][2cm]{%
    \par\vspace{2mm}%
    \begin{tcolorbox}[
        enhanced,
        colback=white,
        colframe=quizSlate!20,
        boxrule=0.5pt,
        arc=3pt,
        outer arc=3pt,
        height=#1,
        left=3mm,
        right=3mm,
        overlay={
            \node[opacity=0.08, anchor=south east] at ([xshift=-2mm, yshift=2mm]frame.south east)
                {\sffamily\small\color{quizSlate}\faPen\hspace{1mm}Show your work};
        },
    ]
    \end{tcolorbox}%
}

%========================================================================================
% 7. QUIZ MULTIPLE CHOICE
%    A/B/C/D answer options in a 2x2 grid layout.
%
%    Usage:
%      \quizQ Which number has a $5$ in the tens place?
%      \quizMC{$352$}{$523$}{$253$}{$235$}
%      \answerMC{A}
%========================================================================================
\newcommand{\quizMC}[4]{%
    \par\vspace{2mm}%
    \noindent\hspace{8mm}%
    \begin{minipage}[t]{0.44\linewidth}
        \sffamily
        \textbf{\textcolor{quizIndigo}{A.}}\hspace{2mm}#1\\[3mm]
        \textbf{\textcolor{quizIndigo}{C.}}\hspace{2mm}#3
    \end{minipage}%
    \hfill
    \begin{minipage}[t]{0.44\linewidth}
        \sffamily
        \textbf{\textcolor{quizIndigo}{B.}}\hspace{2mm}#2\\[3mm]
        \textbf{\textcolor{quizIndigo}{D.}}\hspace{2mm}#4
    \end{minipage}%
    \par\vspace{1mm}%
}

%========================================================================================
% 8. QUIZ TRUE/FALSE
%    True/False checkboxes for a statement.
%
%    Usage:
%      \quizQ The number $456$ has a $5$ in the hundreds place.
%      \quizTF
%      \answerTF{False}
%========================================================================================
\newcommand{\quizTF}{%
    \par\vspace{2mm}%
    \noindent\hspace{8mm}%
    \sffamily
    \textcolor{quizIndigo}{$\bigcirc$}\hspace{2mm}\textbf{True}%
    \hspace{12mm}%
    \textcolor{quizIndigo}{$\bigcirc$}\hspace{2mm}\textbf{False}%
    \par\vspace{1mm}%
}

%========================================================================================
