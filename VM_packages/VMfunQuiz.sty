%----------------------------------------------------------------------------------------
% VMfunQuiz.sty - Quiz & Assessment Environments for Grade 6
% Standalone, timed quizzes (15 min) with name/date fields, auto-numbered
% questions, and a special bonus challenge section.
%
% Design philosophy:
%   - Clean "assessment" feel with approachable, engaging design
%   - Compact: each quiz fits on 1-2 pages
%   - Indigo/gold palette to distinguish from other book types
%   - Each quiz is standalone and mapped to a single topic
%----------------------------------------------------------------------------------------
\ProvidesPackage{VMfunQuiz}[2026/03/02 Grade 6 Quiz Environments]

% tabularx gives auto-expanding X columns — used by quizTable
\RequirePackage{tabularx}

%========================================================================================
% QUIZ-SPECIFIC COLORS
%========================================================================================
\definecolor{quizIndigo}{HTML}{3F51B5}        % Primary quiz color — rich indigo
\definecolor{quizIndigoDark}{HTML}{283593}    % Dark indigo for headers
\definecolor{quizIndigoLight}{HTML}{E8EAF6}   % Light indigo background
\definecolor{quizGold}{HTML}{FFB300}          % Accent — warm gold for stars/highlights
\definecolor{quizGoldDark}{HTML}{FF8F00}      % Darker gold
\definecolor{quizGoldLight}{HTML}{FFF8E1}     % Light gold tint
\definecolor{quizSlate}{HTML}{455A64}         % Slate for body text labels
\definecolor{quizSlateDark}{HTML}{263238}     % Dark slate
\definecolor{quizSlateLight}{HTML}{ECEFF1}    % Light slate for work areas
\definecolor{quizCorrect}{HTML}{43A047}       % Green for correct marks
\definecolor{quizBonusPurple}{HTML}{7E57C2}   % Purple for bonus questions
\definecolor{quizBonusLight}{HTML}{EDE7F6}    % Light purple background

%========================================================================================
% QUIZ COUNTERS
%========================================================================================
\newcounter{quizNumber}                       % Global quiz counter
\setcounter{quizNumber}{0}
\newcounter{quizQuestion}[quizNumber]         % Question counter, resets per quiz
\newcounter{quizChapter}                      % Track which chapter we're in

% Flag: set true by \quizChapterBanner so the first \quizPage skips its \newpage
\newif\ifquizAfterChapter
\quizAfterChapterfalse

% Scratch length used by quizTable to compute equal column widths
\newlength{\quizTabColW}

%========================================================================================
% 0. COMPACT QUIZ CHAPTER STYLE
%    Overrides the full-page TikZ chapter opener with a compact in-page
%    banner so no whole page is wasted between the TOC and the first quiz.
%
%    Call \enableQuizChapterStyle once in the preamble (after \begin{document}
%    is fine, but better in the preamble after loading).
%========================================================================================
\newcommand{\quizChapterBanner}[2]{%
    % #1 = chapter number (may be empty for unnumbered)
    % #2 = chapter title
    % Note: \chapter already issues \clearpage; no extra page break needed here.
    \startcontents[chapters]%
    \vspace*{-\topskip}%
    \begin{tcolorbox}[
        enhanced,
        colback=quizIndigoLight,
        colframe=quizIndigo,
        boxrule=2pt,
        arc=10pt,
        outer arc=10pt,
        top=5mm, bottom=5mm,
        left=6mm, right=6mm,
    ]
        \begin{center}
            \ifx\relax#1\relax\else
                {\fontsize{10}{12}\selectfont\sffamily\color{quizIndigo!70}%
                    C\kern0.1em H\kern0.1em A\kern0.1em P\kern0.1em T\kern0.1em E\kern0.1em R
                    \hspace{2mm}%
                    \begin{tikzpicture}[baseline=-0.5ex]
                        \node[circle, fill=quizGold, draw=quizGoldDark, line width=1.2pt,
                              inner sep=0pt, minimum size=1.5em,
                              font=\sffamily\bfseries\small\color{quizIndigoDark}]
                              {#1};
                    \end{tikzpicture}%
                }\\[2mm]
            \fi
            {\fontsize{18}{22}\selectfont\sffamily\bfseries\color{quizIndigoDark}#2}
        \end{center}
    \end{tcolorbox}%
    % Mini-TOC of quizzes in this chapter
    \begin{tcolorbox}[
        enhanced,
        colback=quizIndigoLight,
        colframe=quizIndigo!30,
        boxrule=0.8pt,
        arc=8pt,
        outer arc=8pt,
        top=2mm, bottom=2mm,
        left=4mm, right=4mm,
    ]
        {\footnotesize\printcontents[chapters]{l}{1}{\setcounter{tocdepth}{1}}}%
    \end{tcolorbox}%
    \vspace{4mm}%
    \quizAfterChaptertrue% suppress the newpage in the first \quizPage of this chapter
}

%========================================================================================
% 0b. \quizChapter{title}
%    Drop-in replacement for \chapter{} in quiz books.
%    Bypasses \titleformat entirely (which would typeset the title as plain text
%    AFTER the before-code, generating a near-blank page).
%    Instead it handles clearpage, counters, TOC entry, header marks, and the
%    compact banner all in one place — exactly like \practiceTestPage does for
%    practice test books.
%
%    Usage: \quizChapter{Multiply, Divide, and Patterns}
%           \setcounter{quizChapter}{1}
%========================================================================================
\newcommand{\quizChapter}[1]{%
    \clearpage
    \refstepcounter{chapter}%
    \chaptermark{#1}%
    \addcontentsline{toc}{chapter}{#1}%
    \startcontents[chapters]%
    % --- Compact chapter banner (indigo tcolorbox) ---
    \begin{tcolorbox}[
        enhanced,
        colback=quizIndigoLight,
        colframe=quizIndigo,
        boxrule=2pt,
        arc=10pt, outer arc=10pt,
        top=5mm, bottom=5mm,
        left=6mm, right=6mm,
    ]
        \begin{center}
            {\fontsize{10}{12}\selectfont\sffamily\color{quizIndigo!70}%
                C\kern0.1em H\kern0.1em A\kern0.1em P\kern0.1em T\kern0.1em E\kern0.1em R
                \hspace{2mm}%
                \begin{tikzpicture}[baseline=-0.5ex]
                    \node[circle, fill=quizGold, draw=quizGoldDark, line width=1.2pt,
                          inner sep=0pt, minimum size=1.6em,
                          font=\sffamily\bfseries\small\color{quizIndigoDark}]
                          {\thechapter};
                \end{tikzpicture}%
            }\\[2mm]%
            {\fontsize{18}{22}\selectfont\sffamily\bfseries\color{quizIndigoDark}#1}
        \end{center}
    \end{tcolorbox}%
    % --- Mini-TOC listing the quizzes in this chapter ---
    \begin{tcolorbox}[
        enhanced,
        colback=quizIndigoLight,
        colframe=quizIndigo!30,
        boxrule=0.8pt,
        arc=8pt, outer arc=8pt,
        top=2mm, bottom=2mm,
        left=4mm, right=4mm,
    ]
        {\footnotesize\printcontents[chapters]{l}{1}{\setcounter{tocdepth}{1}}}%
    \end{tcolorbox}%
    \vspace{4mm}%
    \quizAfterChaptertrue%
}

% \enableQuizChapterStyle is kept for backward compatibility but does nothing;
% the fix is now achieved purely by using \quizChapter instead of \chapter.
\newcommand{\enableQuizChapterStyle}{}

%========================================================================================
% 1. QUIZ PAGE HEADER
%    Full-width banner with quiz number, chapter info, and topic title.
%    Starts a new page and resets question numbering.
%
%    Usage: \quizPage{Place Value: Ones, Tens, Hundreds}
%========================================================================================
\newcommand{\quizPage}[1]{%
    % After a chapter banner, stay on the same page (banner already broke the page).
    % Between quizzes, always start a fresh page.
    \ifquizAfterChapter
        \quizAfterChapterfalse
    \else
        \newpage
    \fi
    \refstepcounter{quizNumber}%
    \setcounter{quizQuestion}{0}%
    \addcontentsline{toc}{section}{Quiz \thequizNumber: #1}%
    % Write quiz marker to answer file (quiz mode)
    \writeAnsQuiz{\thequizNumber}{#1}%
    %
    % --- Quiz banner ---
    \begin{tcolorbox}[
        enhanced,
        colback=quizIndigoLight,
        colframe=quizIndigo,
        boxrule=2pt,
        arc=10pt,
        outer arc=10pt,
        top=4mm,
        bottom=4mm,
        left=5mm,
        right=5mm,
    ]
        \begin{center}
            {\fontsize{11}{13}\selectfont\sffamily\color{quizIndigo!70}%
                \faClipboardCheck\hspace{2mm}%
                CHAPTER \thequizChapter%
            }\\[3mm]
            {\fontsize{22}{26}\selectfont\sffamily\bfseries\color{quizIndigoDark}%
                Quiz \thequizNumber%
            }\\[2mm]
            {\fontsize{13}{16}\selectfont\sffamily\color{quizGoldDark}%
                #1%
            }
        \end{center}
    \end{tcolorbox}%
    \vspace{2mm}%
}

%========================================================================================
% 2. NAME / DATE / SCORE STRIP
%    Compact row with fields for student name, date, and score.
%
%    Usage: \quizInfo     (after \quizPage)
%    Usage: \quizInfo[8]  (custom total score, default is 8)
%========================================================================================
\newcommand{\quizInfo}[1][8]{%
    \begin{tcolorbox}[
        enhanced,
        colback=quizSlateLight,
        colframe=quizSlate!30,
        boxrule=0.8pt,
        arc=6pt,
        outer arc=6pt,
        top=3mm,
        bottom=3mm,
        left=4mm,
        right=4mm,
    ]
        \sffamily\small
        \begin{minipage}[c]{0.48\linewidth}
            \textcolor{quizSlate}{\faUser}\hspace{2mm}%
            \textbf{Name:} \rule[-2pt]{5.5cm}{0.5pt}%
        \end{minipage}%
        \hfill
        \begin{minipage}[c]{0.24\linewidth}
            \textcolor{quizSlate}{\faCalendar}\hspace{2mm}%
            \textbf{Date:} \rule[-2pt]{2cm}{0.5pt}%
        \end{minipage}%
        \hfill
        \begin{minipage}[c]{0.2\linewidth}
            \raggedleft
            \textcolor{quizIndigo}{\faStar}\hspace{1mm}%
            \textbf{Score:} \rule[-2pt]{1cm}{0.5pt}%
            \textbf{/ #1}%
        \end{minipage}%
    \end{tcolorbox}%
    \vspace{2mm}%
}

%========================================================================================
% 3. QUIZ INSTRUCTIONS
