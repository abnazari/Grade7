%========================================================================================
% 13. QUIZ FILL-IN TABLE
%     Full-width equal-column table. Each column is computed as
%     (\linewidth / N) minus padding so the table spans the full page width.
%     Uses plain tabular (not tabularx) so it is safe inside \newenvironment.
%
%     Usage:
%       \begin{quizTable}{3}  % 3 columns
%           A & B & C \\
%           1 & 2 & ? \\
%       \end{quizTable}
%========================================================================================
\newenvironment{quizTable}[1]{%
    \par\vspace{2mm}%
    % colwidth = linewidth/N  minus  2\tabcolsep  minus  \arrayrulewidth
    \setlength{\quizTabColW}{\dimexpr\linewidth/#1 - 2\tabcolsep - \arrayrulewidth\relax}%
    \begin{center}%
    \renewcommand{\arraystretch}{1.5}%
    \sffamily
    \begin{tabular}{|*{#1}{>{\centering\arraybackslash}p{\quizTabColW}|}}
    \hline
    \rowcolor{quizIndigoLight}%
}{%
    \hline
    \end{tabular}
    \end{center}%
    \par\vspace{2mm}%
}

%========================================================================================
% 14. QUIZ MATCHING (draw lines between columns)
%     Two-column layout for matching questions.
%
%     Usage:
%       \quizQ Match each number to its expanded form.
%       \begin{quizMatch}
%           \quizMatchRow{$352$}{$500 + 20 + 3$}
%           \quizMatchRow{$523$}{$300 + 50 + 2$}
%       \end{quizMatch}
%========================================================================================
\newenvironment{quizMatch}{%
    \par\vspace{2mm}%
    \noindent\hspace{8mm}%
    \begin{minipage}{0.85\linewidth}
    \sffamily
    \renewcommand{\arraystretch}{1.6}%
    \begin{tabular}{@{}p{4cm}@{\hspace{2cm}}p{5cm}@{}}
}{%
    \end{tabular}
    \end{minipage}%
    \par\vspace{2mm}%
}
\newcommand{\quizMatchRow}[2]{%
    \textcolor{quizIndigo}{$\bullet$}\hspace{2mm}#1 &
    \textcolor{quizGoldDark}{$\bullet$}\hspace{2mm}#2 \\
}

%========================================================================================
% 15. QUIZ GROUP PICTURE
%     Visual groups of symbols with labels (like the screenshot
%     showing 4 groups of 3 stars). Produces a centered display.
%
%     Usage: \quizGroupPic{4}{3}                 (4 groups of 3 dots)
%     Usage: \quizGroupPic[star]{4}{3}           (4 groups of 3 stars)
%     Usage: \quizGroupPic[heart]{5}{2}          (5 groups of 2 hearts)
%
%     Supported shapes: dot (default), star, heart, circle, square, triangle
%========================================================================================
\newcommand{\quizGroupPic}[3][dot]{%
    \par\vspace{2mm}%
    \begin{center}
    \begin{tikzpicture}
        \foreach \g in {1,...,#2} {
            \pgfmathsetmacro{\gx}{(\g - 1) * (#3 * 0.55 + 0.8)}
            % Draw items in each group
            \foreach \i in {1,...,#3} {
                \pgfmathsetmacro{\ix}{\gx + (\i - 1) * 0.5}
                % Select shape
                \ifnum\pdfstrcmp{#1}{star}=0
                    \node[font=\large] at (\ix, 0) {\textcolor{quizIndigo}{$\bigstar$}};
                \else\ifnum\pdfstrcmp{#1}{heart}=0
                    \node[font=\large] at (\ix, 0) {\textcolor{funRed}{\faHeart}};
                \else\ifnum\pdfstrcmp{#1}{circle}=0
                    \fill[quizIndigo] (\ix, 0) circle (5pt);
                \else\ifnum\pdfstrcmp{#1}{square}=0
                    \fill[quizGold, rounded corners=1pt] ({\ix - 0.15}, -0.15) rectangle ++(0.3, 0.3);
                \else\ifnum\pdfstrcmp{#1}{triangle}=0
                    \node[font=\normalsize] at (\ix, 0) {\textcolor{funGreen}{$\blacktriangle$}};
                \else
                    \fill[quizIndigo] (\ix, 0) circle (4pt);
                \fi\fi\fi\fi\fi
            }
            % Bracket and label (manual drawing instead of brace decoration)
            \pgfmathsetmacro{\braceLeft}{\gx - 0.15}
            \pgfmathsetmacro{\braceRight}{\gx + (#3 - 1) * 0.5 + 0.15}
            \pgfmathsetmacro{\braceMid}{(\braceLeft + \braceRight) / 2}
            \draw[thick, quizSlate]
                (\braceLeft, -0.35) -- (\braceLeft, -0.45)
                -- (\braceMid, -0.55)
                -- (\braceRight, -0.45)
                -- (\braceRight, -0.35);
            \node[below, font=\small\sffamily, text=quizSlate] at
                (\braceMid, -0.6) {group \g};
        }
    \end{tikzpicture}
    \end{center}
    \vspace{1mm}%
}

%========================================================================================
% 16. QUIZ FILL-IN SENTENCE
%     Formatted multiplication/division sentence with styled answer blanks.
%     Each blank is a tcolorbox-styled underline.
%
%     Usage: \quizSentence{$\times$}    % ___ × ___ = ___
%     Usage: \quizSentence{$\div$}      % ___ ÷ ___ = ___
%     Usage: \quizSentence{$+$}         % ___ + ___ = ___
%========================================================================================
\newcommand{\quiz@styledblank}{%
    \tikz[baseline=-3pt]{%
        \draw[quizIndigo, thick] (0, 0) -- (2, 0);
        \fill[quizIndigoLight, opacity=0.5, rounded corners=2pt] (-0.05, -0.1) rectangle (2.05, 0.45);
    }%
}
\newcommand{\quizSentence}[1]{%
    \par\vspace{3mm}%
    \begin{center}
        \Large\sffamily
        \quiz@styledblank
        \hspace{3mm}#1\hspace{3mm}%
        \quiz@styledblank
        \hspace{3mm}$=$\hspace{3mm}%
        \quiz@styledblank
    \end{center}
    \vspace{2mm}%
}

%========================================================================================
% 17. QUIZ COMPARE
%     Two values side by side with a single empty circle in the middle.
%     Students write >, <, or = inside the circle.
%
%     Usage: \quizCompare{$345$}{$354$}
%     Usage: \quizCompare{$2 \times 5$}{$3 \times 3$}
%========================================================================================
\newcommand{\quizCompare}[2]{%
    \par\vspace{2mm}%
    \begin{center}
    \begin{tikzpicture}
        % Left value box
        \node[
            fill=quizIndigoLight,
            rounded corners=6pt,
            inner sep=6pt,
            font=\Large\sffamily\bfseries,
            minimum width=2.5cm,
            minimum height=1cm,
        ] (left) at (0, 0) {#1};
        % Single empty write-in circle
        \node[
            draw=quizSlate, thick, circle,
            minimum size=1cm,
            inner sep=0pt,
        ] (cmp) at (3.2, 0) {};
        % Right value box
        \node[
            fill=quizGoldLight,
            rounded corners=6pt,
            inner sep=6pt,
            font=\Large\sffamily\bfseries,
            minimum width=2.5cm,
            minimum height=1cm,
        ] (right) at (6.4, 0) {#2};
    \end{tikzpicture}
    \end{center}
    \vspace{1mm}%
}

%========================================================================================
% 18. QUIZ CIRCLE CHOICE (standard multiple-choice layout)
%     Circle-bubble multiple choice — no TikZ, no overlap.
%     2 non-empty args  → single inline row with two bubbles.
%     3-4 non-empty args → 2×2 minipage grid matching \quizMC layout.
%     Empty trailing args are silently omitted.
%
%     Usage: \quizCircle{$12$}{$15$}{$18$}{$21$}
%     Usage: \quizCircle{True}{False}{}{}
%========================================================================================
\newcommand{\quizCircle}[4]{%
    \par\vspace{2mm}%
    \def\quizCargC{#3}\def\quizCargD{#4}\def\quizCempty{}%
    \noindent\hspace{8mm}%
    \ifx\quizCargC\quizCempty
        % ---- 2-option inline layout ----
        \sffamily
        \textcolor{quizIndigo}{$\bigcirc$}\hspace{2mm}\textbf{#1}%
        \hspace{10mm}%
        \textcolor{quizIndigo}{$\bigcirc$}\hspace{2mm}\textbf{#2}%
    \else
        % ---- 4-option 2x2 grid layout ----
        \begin{minipage}[t]{0.44\linewidth}
            \sffamily
            \textcolor{quizIndigo}{$\bigcirc$}\hspace{2mm}#1\\[3mm]
            \textcolor{quizIndigo}{$\bigcirc$}\hspace{2mm}#3%
        \end{minipage}%
        \hfill
        \begin{minipage}[t]{0.44\linewidth}
            \sffamily
            \textcolor{quizIndigo}{$\bigcirc$}\hspace{2mm}#2\\[3mm]
            \ifx\quizCargD\quizCempty\else
                \textcolor{quizIndigo}{$\bigcirc$}\hspace{2mm}#4%
            \fi
        \end{minipage}%
    \fi
    \par\vspace{1mm}%
}

%========================================================================================
% 19. QUIZ ANSWER LINE (formatted answer area with label)
%     Shows a labeled answer line for short-answer questions.
%
%     Usage: \quizAnswerLine{Answer}
%     Usage: \quizAnswerLine{Value of digit}
%========================================================================================
\newcommand{\quizAnswerLine}[1]{%
    \par\vspace{2mm}%
    \noindent\hspace{8mm}%
    {\small\sffamily\color{quizSlate}#1:\hspace{3mm}}%
    \rule[-2pt]{5cm}{0.5pt}%
    \par\vspace{1mm}%
}

%========================================================================================
% 20. RESET QUIZ QUESTIONS
%     Reset the question counter (useful if using \prob from VMfunPractice
%     instead of \quizQ).
%
%     Usage: \resetQuiz
%========================================================================================
\newcommand{\resetQuiz}{%
    \setcounter{quizQuestion}{0}%
}
