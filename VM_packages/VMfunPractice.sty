%% Pictograph row: label + repeated symbols
%% Usage: \picRow{Apples}{5}   (5 stars)
%% Optional symbol: \picRow[\faHeart]{Red}{3}
\newcommand{\picRow}[3][\faStar]{%
    \par\vspace{2mm}\noindent
    \makebox[3cm][r]{\sffamily\bfseries #2}\hspace{5mm}%
    \foreach \s in {1,...,#3} {%
        {\color{funYellow}\large #1}~%
    }%
    \par\vspace{2mm}%
}

%% Pictograph key/legend
%% Usage: \picKey{2 students}
\newcommand{\picKey}[2][\faStar]{%
    \par\vspace{4mm}%
    {\small\sffamily\itshape\color{funGrayDark}Key:\hspace{2mm}Each {\color{funYellow}#1} $=$ #2}%
    \par%
}

