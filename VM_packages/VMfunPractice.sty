%========================================================================================
% 20. PRACTICE QUESTION COMPONENTS
%     Environments and commands for the Practice Question Bank format.
%     DESIGN: Print-friendly — no heavy fills. Uses thin left borders and
%     subtle accents that remain readable in B&W.  Color adds charm but is
%     not required for comprehension.
%========================================================================================

% ── Cycling accent colours (print-friendly: only used for thin borders) ──
\newcounter{ptQColor}           % cycles 0-1-2 per question
\newcommand{\ptCurrentColor}{funBlue}
\newcommand{\ptCurrentColorLight}{funBlueLight}
\newcommand{\ptAdvanceColor}{%
    \stepcounter{ptQColor}%
    \ifcase\value{ptQColor}\relax
        \renewcommand{\ptCurrentColor}{funBlue}%
        \renewcommand{\ptCurrentColorLight}{funBlueLight}%
    \or
        \renewcommand{\ptCurrentColor}{funGreen}%
        \renewcommand{\ptCurrentColorLight}{funGreenLight}%
    \or
        \renewcommand{\ptCurrentColor}{funTeal}%
        \renewcommand{\ptCurrentColorLight}{funTealLight}%
        \setcounter{ptQColor}{-1}%  wrap around
    \fi
}

% ── Boolean: is current question short-answer? ──
\newif\ifptSA

% ── Wrapper for a single question (ID, Type) ─────────────────────────────
%    Thin coloured left border (2.5pt), white body, rounded corners.
%    NO background fill — safe for B&W printing.
\newtcolorbox{practiceQuestion}[2]{
    enhanced,
    colback=white,
    colframe=\ptCurrentColor!25,
    boxrule=0.4pt,
    borderline west={2.5pt}{0pt}{\ptCurrentColor!60},
    arc=6pt,
    outer arc=6pt,
    left=4mm, right=3mm,
    top=3mm, bottom=3mm,
    before skip=6pt,
    after skip=6pt,
    unbreakable,
    before upper={\ptAdvanceColor
        \def\ptArgType{#2}%
        \def\ptSALabel{sa}%
        \def\ptGSALabel{gsa}%
        \ptSAfalse
        \ifx\ptArgType\ptSALabel\ptSAtrue\fi
        \ifx\ptArgType\ptGSALabel\ptSAtrue\fi
    },
    after upper={%
        % ── Auto-insert answer box for SA questions ──
        \ifptSA
            \par\vspace{3mm}%
            \noindent
            \begin{tikzpicture}
                \draw[rounded corners=4pt, \ptCurrentColor!40, thick, densely dashed]
                    (0,0) rectangle (\linewidth - 2mm, 1.3cm);
                \node[anchor=north west, font=\footnotesize\sffamily\color{\ptCurrentColor!60},
                      inner sep=0pt]
                    at (3mm, 1.3cm - 2mm) {Your Answer:};
                % Writing line
                \draw[\ptCurrentColor!25] (3mm, 4mm) -- (\linewidth - 5mm, 4mm);
            \end{tikzpicture}%
        \fi
    },
}

% ── Question Text Environment ────────────────────────────────────────────
%    Number rendered as bold "N." label — distinct from circled option letters.
\newenvironment{questionText}{%
    \stepcounter{funProblem}%
    \par\noindent
    {\bfseries\sffamily\color{\ptCurrentColor!85}\thefunProblem.}\hspace{2.5mm}%
    \ignorespaces
}{%
    \par\vspace{2mm}%
}

% ── Helper: single choice cell with circled letter ───────────────────────
%    All letters use the same neutral gray so they print identically in B&W.
%    Circle is slightly larger and vertically centred with the text.
\newcommand{\ptChoiceCell}[2]{%  #1=letter, #2=content
    \tikz[baseline=-0.5ex]{%
        \node[circle, draw=black!45, line width=0.7pt,
              inner sep=0pt, minimum size=0.5cm,
              font=\footnotesize\bfseries\sffamily\color{black!65}] {#1};%
    }\hspace{2mm}#2%
}

% ── Multiple Choice Options — styled 2×2 grid ───────────────────────────
%    All letters use a uniform gray circle. No divider line between rows.
\newcommand{\ptChoiceA}{}
\newcommand{\ptChoiceB}{}
\newcommand{\ptChoiceC}{}
\newcommand{\choiceA}[1]{\renewcommand{\ptChoiceA}{#1}}
\newcommand{\choiceB}[1]{\renewcommand{\ptChoiceB}{#1}}
\newcommand{\choiceC}[1]{\renewcommand{\ptChoiceC}{#1}}
\newcommand{\choiceD}[1]{%
    \par\vspace{3mm}%
    \noindent
    \begin{tabular}{@{\hspace{3mm}}p{0.44\linewidth}@{\hspace{6mm}}p{0.44\linewidth}@{}}
        \ptChoiceCell{A}{\ptChoiceA} &
        \ptChoiceCell{B}{\ptChoiceB} \\[4mm]
        \ptChoiceCell{C}{\ptChoiceC} &
        \ptChoiceCell{D}{#1} \\
    \end{tabular}%
    \par\vspace{2mm}%
}

% ── Short Answer Section Divider ─────────────────────────────────────────
%    Inserted by the Python generator between MC and SA blocks.
\newcommand{\practiceTestSASection}{%
    \par\vspace{6mm}%
    \noindent
    \begin{tikzpicture}
        \draw[funTeal!40, line width=0.8pt] (0,0) -- (\linewidth, 0);
        \node[fill=white, inner xsep=6mm, inner ysep=1mm,
              font=\normalsize\bfseries\sffamily\color{funTealDark}]
            at (0.5\linewidth, 0)
            {\faPen\hspace{2.5mm}Short Answer\hspace{2.5mm}\faPen};
    \end{tikzpicture}%
    \par\vspace{4mm}%
}

