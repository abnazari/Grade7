\ProvidesPackage{VMfunPractice}[2026/03/02 Grade 7 Practice Environments]

%========================================================================================
% 1. PRACTICE BOX
%    A titled practice section with numbered problems.
%    Design: Blue header with pencil decorations, white/light blue content.
%    Usage: \begin{practiceBox}{Addition Practice} ... \end{practiceBox}
%    Optional color: \begin{practiceBox}[funGreen]{...} ... \end{practiceBox}
%========================================================================================

% ICON NEEDED: Writing pencil icon (yellow pencil, slightly tilted)
% File: icons/writing-pencil.pdf

\newtcolorbox{practiceBox}[2][funBlue]{
    enhanced,
    colback=white,
    colframe=#1,
    colbacktitle=#1!15,
    coltitle=#1!80!black,
    fonttitle=\Large\bfseries\sffamily,
    title={\raisebox{-0.1em}{\color{#1}\faPen}~~#2~~\raisebox{-0.1em}{\color{#1}\faPen}},
    halign title=center,
    arc=8pt,
    outer arc=8pt,
    boxrule=1.5pt,
    top=5mm,
    bottom=5mm,
    left=5mm,
    right=5mm,
    toptitle=4mm,
    bottomtitle=4mm,
    before={\par\addvspace{10pt}},
    after skip=8pt,
    breakable,
}

%========================================================================================
% 2. PRACTICE SUBSECTION HEADER
%    A colored header bar inside practice boxes to separate sections.
%    Design: Colored bar with white or colored text.
%    Usage: \practiceHeader{Add These 3-Digit Numbers}
%    Optional: \practiceHeader[funOrange]{Show Your Work}
%========================================================================================
\newcommand{\practiceHeader}[2][funBlue]{%
    \par\vspace{4mm}%
    \begin{tcolorbox}[
        enhanced,
        colback=#1!15,
        colframe=#1,
        boxrule=1pt,
        arc=5pt,
        outer arc=5pt,
        left=4mm, right=4mm,
        top=2mm, bottom=2mm,
    ]
        {\bfseries\sffamily\color{#1!80!black}#2}
    \end{tcolorbox}
    \vspace{2mm}%
}

