%========================================================================================
% 7. PROBLEM NUMBERING SYSTEM
%    Auto-numbered problems for practice sections.
%========================================================================================
\newcounter{funProblem}[section]

\newcommand{\prob}{%
    \stepcounter{funProblem}%
    \par\vspace{2mm}\noindent
    \textbf{\sffamily\thefunProblem.}\hspace{3mm}%
}

%% Inline problem (for grid layouts)
\newcommand{\probInline}{%
    \stepcounter{funProblem}%
    \textbf{\sffamily\thefunProblem.}\hspace{2mm}%
}

%% Reset problem counter
\newcommand{\resetProblems}{\setcounter{funProblem}{0}}

%========================================================================================
% 8. ANSWER SPACE (vertical space for student work)
%    Usage: \answerSpace  or  \answerSpace[3cm]
%========================================================================================
\newcommand{\answerSpace}[1][2cm]{%
    \par\vspace{#1}%
}

%========================================================================================
% 9. WORD PROBLEM
%    A styled word problem with answer line.
%    Usage: \wordProblem{A library has 375 math books and 248 science books.
%            How many books are in total?}{books}
%========================================================================================
\newcommand{\wordProblem}[2]{%
    \par\vspace{3mm}\noindent
    \stepcounter{funProblem}%
    \textbf{\sffamily\thefunProblem.}~#1%
    \par\vspace{2mm}%
    \hfill\textbf{Answer:}~\answerBlank~#2%
    \par\vspace{3mm}%
}

%========================================================================================
% 10. TRUE OR FALSE
%     Usage: \trueOrFalse{$5 \times 3 = 15$}
%========================================================================================
\newcommand{\trueOrFalse}[1]{%
    \par\vspace{2mm}\noindent
    \stepcounter{funProblem}%
    \textbf{\sffamily\thefunProblem.}~#1\hfill%
    \textbf{True}~{\color{funGreen}\faCircle[regular]}\hspace{5mm}\textbf{False}~{\color{funRed}\faCircle[regular]}%
    \par\vspace{2mm}%
}

%========================================================================================
% 11. MULTIPLE CHOICE
%     Usage: \multiChoice{What is $12 \div 3$?}{2}{3}{4}{6}
%========================================================================================
\newcommand{\multiChoice}[5]{%
    \par\vspace{2mm}\noindent
    \stepcounter{funProblem}%
    \textbf{\sffamily\thefunProblem.}~#1%
    \par\vspace{1mm}%
    \hspace{5mm}\textbf{A.}~#2\hspace{8mm}%
    \textbf{B.}~#3\hspace{8mm}%
    \textbf{C.}~#4\hspace{8mm}%
    \textbf{D.}~#5%
    \par\vspace{2mm}%
}

%========================================================================================
% 11b. MULTIPLE CHOICE — 2×2 GRID LAYOUT
%     Like \multiChoice but displays A+B on row 1, C+D on row 2.
%     Usage: \multiChoiceGrid{Question}{A}{B}{C}{D}
%========================================================================================
\newcommand{\multiChoiceGrid}[5]{%
    \par\vspace{2mm}\noindent
    \stepcounter{funProblem}%
    \textbf{\sffamily\thefunProblem.}~#1%
    \par\vspace{1mm}%
    \hspace{5mm}\textbf{A.}~#2\hspace{12mm}\textbf{B.}~#3%
    \par\vspace{1mm}%
    \hspace{5mm}\textbf{C.}~#4\hspace{12mm}\textbf{D.}~#5%
    \par\vspace{2mm}%
}

%========================================================================================
% 12. CIRCLE THE ANSWER
%     Usage: \circleAnswer{Which is the correct answer?}{15}{20}{25}{30}
%========================================================================================
\newcommand{\circleAnswer}[5]{%
    \par\vspace{2mm}\noindent
    \stepcounter{funProblem}%
    \textbf{\sffamily\thefunProblem.}~#1%
    \par\vspace{1mm}\hspace{5mm}%
    \tikz[baseline=-0.3ex]{\node[draw=funGray, rounded corners=3pt, inner sep=4pt]{#2};}%
    \hspace{5mm}%
    \tikz[baseline=-0.3ex]{\node[draw=funGray, rounded corners=3pt, inner sep=4pt]{#3};}%
    \hspace{5mm}%
    \tikz[baseline=-0.3ex]{\node[draw=funGray, rounded corners=3pt, inner sep=4pt]{#4};}%
    \hspace{5mm}%
    \tikz[baseline=-0.3ex]{\node[draw=funGray, rounded corners=3pt, inner sep=4pt]{#5};}%
    \par\vspace{2mm}%
}

