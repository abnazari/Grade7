%========================================================================================
% 17. CODE BREAKER (solve math problems to decode a secret message)
%     Students solve problems, each answer maps to a letter, then decode a message.
%     Design: Purple theme with key icon — feels like a secret spy mission.
%     Usage:
%       \begin{codeBreaker}
%           \codeClue{A}{$3 \times 4$}
%           \codeClue{T}{$20 \div 5$}
%           \secretMessage{12 \quad 4 \quad 12}
%       \end{codeBreaker}
%========================================================================================
\newtcolorbox{codeBreaker}[1][Code Breaker]{
    enhanced,
    colback=funPurple!4,
    colframe=funPurple,
    colbacktitle=funPurple!15,
    coltitle=funPurpleDark,
    fonttitle=\large\bfseries\sffamily,
    title={\raisebox{-0.1em}{\color{funPurpleDark}\faKey}~~#1},
    arc=8pt,
    outer arc=8pt,
    boxrule=1.5pt,
    top=5mm, bottom=5mm,
    left=5mm, right=5mm,
    toptitle=3mm, bottomtitle=3mm,
    before skip=8pt, after skip=8pt,
    breakable,
    overlay={
        \node[opacity=0.06] at ([xshift=-8mm, yshift=8mm]frame.south east)
            {\textcolor{funPurple}{\fontsize{28}{30}\selectfont\faKey}};
    },
}

%% Code clue: letter-circle followed by a problem
%% Usage: \codeClue{A}{$5 \times 6$}
\newcommand{\codeClue}[2]{%
    \par\vspace{2mm}\noindent
    \tikz[baseline=-0.3ex]{\node[circle, fill=funPurple, text=white, inner sep=2pt,
          font=\small\bfseries\sffamily, minimum size=0.55cm]{#1};}%
    \hspace{3mm}#2\hspace{3mm}$=$\hspace{2mm}\answerBlank[2cm]%
    \par\vspace{2mm}%
}

%% Secret message decoder line
%% Usage: \secretMessage{Write the secret message format here}
\newcommand{\secretMessage}[1]{%
    \par\vspace{4mm}%
    \begin{center}
    \begin{tcolorbox}[
        enhanced,
        colback=funPurple!6,
        colframe=funPurple!40,
        boxrule=1pt,
        arc=6pt,
        outer arc=6pt,
        width=0.85\linewidth,
        halign=center,
        top=4mm, bottom=4mm,
        left=5mm, right=5mm,
    ]
        {\sffamily\bfseries\color{funPurpleDark}\faLock~~Secret Message:}\\[3mm]#1
    \end{tcolorbox}
    \end{center}
}

