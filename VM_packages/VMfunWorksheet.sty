%========================================================================================
% 1. WORKSHEET HEADER
%    Full-width banner with worksheet number, title, and name/date/score fields.
%    Starts a new page. Does NOT touch funProblem — use \prob for numbering.
%
%    Usage: \worksheetHeader{Place Value Speed Round}
%========================================================================================
\newcommand{\worksheetHeader}[1]{%
    \newpage
    \stepcounter{wsNumber}%
    \gdef\wsans@title{#1}%
    %
    % --- Worksheet banner ---
    \begin{tcolorbox}[
        enhanced,
        colback=wsGreenLight,
        colframe=wsGreen,
        boxrule=2pt,
        arc=10pt,
        outer arc=10pt,
        top=4mm,
        bottom=4mm,
        left=5mm,
        right=5mm,
    ]
        \begin{center}
            {\fontsize{11}{13}\selectfont\sffamily\color{wsGreen!70}%
                \faPen\hspace{2mm}%
                WORKSHEET \thewsNumber%
            }\\[1mm]
            {\fontsize{18}{22}\selectfont\sffamily\bfseries\color{wsGreenDark}%
                #1%
            }
        \end{center}
    \end{tcolorbox}%
    \vspace{1mm}%
    % --- Name / Date / Score strip ---
    \begin{tcolorbox}[
        enhanced,
        colback=white,
        colframe=wsSlate!20,
        boxrule=0.8pt,
        arc=6pt,
        outer arc=6pt,
        top=3mm,
        bottom=3mm,
        left=4mm,
        right=4mm,
    ]
        \sffamily\small
        \begin{minipage}[c]{0.48\linewidth}
            \textcolor{wsSlate}{\faUser}\hspace{2mm}%
            \textbf{Name:} \rule[-2pt]{5.5cm}{0.5pt}%
        \end{minipage}%
        \hfill
        \begin{minipage}[c]{0.24\linewidth}
            \textcolor{wsSlate}{\faCalendar}\hspace{2mm}%
            \textbf{Date:} \rule[-2pt]{2cm}{0.5pt}%
        \end{minipage}%
        \hfill
        \begin{minipage}[c]{0.2\linewidth}
            \raggedleft
            \textcolor{wsGreen}{\faStar}\hspace{1mm}%
            \textbf{Score:} \rule[-2pt]{1cm}{0.5pt}%
        \end{minipage}%
    \end{tcolorbox}%
    \vspace{2mm}%
}

