    \end{center}
    \vspace{4mm}%
}

%========================================================================================
% 17. WORKSHEET ANSWER COLLECTION SYSTEM
%    Collects worksheet answers during compilation and prints them at the end of the book.
%    Nothing is displayed inline — answers appear only in the Worksheet Solutions chapter.
%    Modeled on the puzzle answer system (\puzzleAnswer in VMfunPuzzles.sty).
%
%    Usage in topic files:   \worksheetAnswer{All six values: $400$, $80$, ... because ...}
%    Usage in main .tex:     \printWorksheetAnswers   (at the very end, before \end{document})
%========================================================================================

% --- Current worksheet title (set by \worksheetHeader) ---
\def\wsans@title{}
% --- Answer file handle ---
\newwrite\wsans@file
\immediate\openout\wsans@file=\jobname.wsans
\newif\ifwsans@collecting
\wsans@collectingtrue

% --- Worksheet answer counter (resets per section) ---
\newcounter{wsAnsNum}
\setcounter{wsAnsNum}{0}

% --- Track chapter / section changes ---
\def\wsans@lastch{}
\def\wsans@lastsec{}

% --- \worksheetAnswer{text}  — collects silently, displays nothing inline ---
\newcommand{\worksheetAnswer}[1]{%
    \ifwsans@collecting
        % Detect chapter change
        \edef\wsans@currch{\thechapter}%
        \ifx\wsans@currch\wsans@lastch\else
            \immediate\write\wsans@file{\string\wsAnsChap{\thechapter}}%
            \global\let\wsans@lastch\wsans@currch
        \fi
        % Detect section change (resets worksheet answer counter)
        \edef\wsans@currsec{\thesection}%
        \ifx\wsans@currsec\wsans@lastsec\else
            \immediate\write\wsans@file{\string\wsAnsSec{\thesection}}%
            \global\let\wsans@lastsec\wsans@currsec
            \setcounter{wsAnsNum}{0}%
        \fi
        % Increment worksheet number and write entry
        \stepcounter{wsAnsNum}%
        \immediate\write\wsans@file{%
            \string\wsAnsItem{\thewsAnsNum}{\noexpand\textbf{\wsans@title:}~\unexpanded{#1}}%
        }%
    \fi
}

% --- Color cycling for section accents ---
\newcounter{wsans@seccolor}
\setcounter{wsans@seccolor}{0}
\newcommand{\wsans@secaccent}{%
    \ifcase\value{wsans@seccolor}%
        wsGreen%        0
    \or wsTeal%         1
    \or wsBlue%         2
    \or wsOrange%       3
    \or wsPink%         4
    \or wsPurple%       5
    \fi
}
\newcommand{\wsans@nextsec}{%
    \stepcounter{wsans@seccolor}%
    \ifnum\value{wsans@seccolor}>5 \setcounter{wsans@seccolor}{0}\fi
}

% --- Color cycling for answer number badges ---
\newcounter{wsans@numcolor}
\setcounter{wsans@numcolor}{0}
\newcommand{\wsans@badgecolor}{%
    \ifcase\value{wsans@numcolor}%
        wsGreen%        0
    \or wsTeal%         1
    \or wsBlue%         2
    \or wsOrange%       3
    \or wsPink%         4
    \or wsPurple%       5
    \fi
}
\newcommand{\wsans@nextbadge}{%
    \stepcounter{wsans@numcolor}%
    \ifnum\value{wsans@numcolor}>5 \setcounter{wsans@numcolor}{0}\fi
}

%========================================================================================
% 18. PRINT WORKSHEET ANSWERS — Call once at the end of the book
%    Reads the .wsans file and renders all collected answers grouped by chapter/section.
%
%    Usage:  \printWorksheetAnswers
%========================================================================================
\newcommand{\printWorksheetAnswers}{%
    % Close the file so it can be read back
    \immediate\closeout\wsans@file
    \global\wsans@collectingfalse
    %
    % ===== Title =====
    \chapter*{Worksheet Solutions}
    \addcontentsline{toc}{chapter}{Worksheet Solutions}
    \markboth{Worksheet Solutions}{Worksheet Solutions}
    %
    % ===== Header banner =====
    \begin{center}
    \begin{tcolorbox}[
        enhanced,
        colback=wsGreenLight,
        colframe=wsGreen!60,
        boxrule=2pt,
        arc=14pt,
        outer arc=14pt,
        width=0.92\linewidth,
        halign=center,
        top=6mm, bottom=6mm,
    ]
        {\fontsize{22}{26}\selectfont\bfseries\sffamily\color{wsGreenDark}%
            \faPen\hspace{4mm}Worksheet Solutions\hspace{4mm}\faPen%
        }\\[4mm]
        {\large\sffamily\color{funGrayDark}%
        Try each worksheet on your own first!\\[1mm]
        Then check here to see how you did.%
        }
    \end{tcolorbox}
    \end{center}
    \vspace{6mm}
    %
    % ===== Define rendering commands for .wsans entries =====
    %
    % --- CHAPTER HEADER ---
    \def\wsAnsChap##1{%
        \par\vspace{8mm}%
        \setcounter{wsans@seccolor}{0}%
        \noindent
        \begin{tcolorbox}[
            enhanced,
            colback=wsGreenLight,
            colframe=wsGreen,
            boxrule=2pt,
            arc=8pt,
            outer arc=8pt,
            left=6mm, right=6mm,
            top=3.5mm, bottom=3.5mm,
        ]
            {\Large\bfseries\sffamily\color{wsGreenDark}%
                \faPen\hspace{4mm}Chapter~##1%
            }%
        \end{tcolorbox}%
        \vspace{1mm}%
    }%
    %
    % --- SECTION HEADER ---
    \def\wsAnsSec##1{%
        \par\vspace{5mm}%
        \setcounter{wsans@numcolor}{0}%
        \noindent
        \begin{tcolorbox}[
            enhanced,
            colback=\wsans@secaccent!10,
            colframe=\wsans@secaccent!50,
            boxrule=1pt,
            arc=6pt,
            outer arc=6pt,
            left=5mm, right=5mm,
            top=2.5mm, bottom=2.5mm,
        ]
            {\bfseries\sffamily\color{\wsans@secaccent!85!black}%
                \faKey\hspace{2mm}Section~##1%
            }%
        \end{tcolorbox}%
        \vspace{3mm}\noindent
        \wsans@nextsec
    }%
    %
    % --- ANSWER ITEM: worksheet number badge + solution text ---
    \def\wsAnsItem##1##2{%
        \par\noindent
        \begin{tcolorbox}[
            enhanced,
            colback=\wsans@badgecolor!4,
            colframe=\wsans@badgecolor!25,
            boxrule=0.6pt,
            arc=5pt,
            outer arc=5pt,
            left=4mm, right=4mm,
            top=2.5mm, bottom=2.5mm,
            before skip=2.5mm,
            after skip=2.5mm,
            breakable,
        ]
            \sffamily\small
            \tikz[baseline=-0.3ex]{%
                \node[circle, fill=\wsans@badgecolor!70, text=white,
                      inner sep=0pt, minimum size=7mm,
                      font=\small\bfseries\sffamily]{##1};%
            }\hspace{2.5mm}%
            {\color{funGrayDark}##2}%
        \end{tcolorbox}%
        \wsans@nextbadge
    }%
    %
    % ===== Read and render the collected answers =====
    \setlength{\parindent}{0pt}%
    \InputIfFileExists{\jobname.wsans}{}{%
        \textit{No worksheet answers found. Compile again to generate solutions.}%
    }%
    %
    % ===== Footer =====
    \par\vspace{8mm}%
    \begin{center}
        {\Large\color{wsGreen}\faCheck}\\[2mm]
        {\large\sffamily\color{funGrayDark}\bfseries Worksheet solutions complete.}\\[1mm]
        {\sffamily\color{funGray} Review any activities you found challenging and try them again.}
    \end{center}
}
