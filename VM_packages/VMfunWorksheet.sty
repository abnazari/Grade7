%% Number bubbles: displays numbers in circles for circling activities
%% Usage: \numberBubbles{12,15,18,21,24,25,27,30}
%% Usage: \numberBubbles[wsPink]{12,15,18,21,24}
\newcommand{\numberBubbles}[2][wsPink]{%
    \begin{center}
    \begin{tikzpicture}
    \foreach \val [count=\idx from 0] in {#2} {
        \pgfmathsetmacro{\row}{int(\idx / 5)}
        \pgfmathsetmacro{\col}{mod(\idx, 5)}
        \pgfmathsetmacro{\xpos}{\col * 2.2}
        \pgfmathsetmacro{\ypos}{-\row * 2.0}
        \node[circle, draw=#1!50, line width=1.2pt, fill=white,
              minimum size=1.4cm, font=\large\sffamily\bfseries]
            at (\xpos, \ypos) {\val};
    }
    \end{tikzpicture}
    \end{center}
}

