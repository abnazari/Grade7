%----------------------------------------------------------------------------------------
% VMfunDays.sty — Day-specific environments for "In 30 Days" book type
%
%   dayPage         Full-page day opener with day number & title
%   todaysGoals     Orange goals box  — what you'll learn today
%   quickLesson     Compact concept teaching box
%   dailyPractice   Practice section for the day
%   dailyChallenge  End-of-day bonus challenge
%   dayComplete     Checkmark "I did it!" end-of-day marker
%   weeklyReview    End-of-week review section
%   bonusLesson     State-specific bonus content box
%   progressBar     Visual 30-day progress tracker
%   minuteTimer     Estimated time indicator
%----------------------------------------------------------------------------------------
\ProvidesPackage{VMfunDays}[2026/03/02 Grade 7 - Day Environments for 30 Days Book]

% Safety: \writeAnsDay is defined in VMfunAnswers.sty. Provide a no-op fallback
% so VMfunDays can be loaded independently without errors.
\providecommand{\writeAnsDay}[2]{}

%----------------------------------------------------------------------------------------
% DAY PAGE — Full-page day opener
%   #1 = day number
%   #2 = day title (topic name)
%   #3 = brief description / topics covered
%----------------------------------------------------------------------------------------
\newcommand{\dayPage}[3]{%
    \newpage
    \thispagestyle{empty}%
    \refstepcounter{dayNumber}%
    %
    % Register this day in the TOC (feeds the mini week TOC).
    % Uses custom 'dayentry' level (depth 1) so it is distinct from \section
    % entries — the mini week-TOC shows only Day N entries, never the 1.1 headers.
    \phantomsection
    \addcontentsline{toc}{dayentry}{Day #1: #2}%
    % Write a day marker to the answer key file (day mode only — no-op otherwise)
    \writeAnsDay{#1}{#2}%
    %
    % Update headers for this day
    \markboth{\sffamily\normalsize\bfseries Day #1: #2}%
             {\sffamily\normalsize Day #1: #2}%
    %
    \begin{tikzpicture}[remember picture, overlay]
        %
        % ============ BACKGROUND ============
        \fill[funOrange!4]
            (current page.south west) rectangle (current page.north east);
        %
        % ============ TOP GRADIENT BAND ============
        \shade[left color=funOrange!25, right color=funYellow!20]
            (current page.north west) rectangle
            ([yshift=-9cm]current page.north east);
        %
        % Diagonal accent
        \fill[funOrange!20]
            ([yshift=-9cm]current page.north west) --
            ([yshift=-9cm]current page.north east) --
            ([yshift=-9.8cm]current page.north east) --
            ([yshift=-9.4cm]current page.north west) -- cycle;
        %
        % ============ DECORATIVE ELEMENTS ============
        \fill[funOrange, opacity=0.04]
            ([xshift=-3cm, yshift=-1.5cm]current page.north east) circle (4cm);
        \fill[funOrange, opacity=0.03]
            ([xshift=2cm, yshift=-5.5cm]current page.north west) circle (3cm);
        %
        % Small calendar icon
        \node[opacity=0.12] at ([xshift=2cm, yshift=-1.3cm]current page.north west)
            {\textcolor{funOrange}{\fontsize{24}{26}\selectfont\faCalendarDay}};
        %
        % ============ "DAY" LABEL ============
        \node[
            font=\fontsize{14}{17}\selectfont\sffamily\color{funOrange!60},
            inner sep=0pt,
        ] at ([yshift=-2cm]current page.north)
            {D\kern0.15em A\kern0.15em Y};
        %
        % ============ DAY NUMBER — Large calendar square ============
        % Shadow
        \fill[funOrangeDark, opacity=0.1, rounded corners=6pt]
            ([xshift=1.5mm, yshift=-5.2cm]current page.north) rectangle ++(3.2cm, -3.2cm);
        % Main square
        \node[
            rounded corners=6pt,
            fill=white,
            draw=funOrange, line width=2.5pt,
            inner sep=0pt, minimum size=3cm,
            font=\fontsize{48}{52}\selectfont\sffamily\bfseries\color{funOrangeDark},
        ] at ([yshift=-4.5cm]current page.north) {#1};
        %
        % ============ DAY TITLE ============
        \node[
            text width=0.82\paperwidth, align=center,
            font=\fontsize{22}{28}\selectfont\sffamily\bfseries\color{funOrangeDark},
        ] at ([yshift=-7.2cm]current page.north) {#2};
        %
        % ============ DIVIDER ============
        \draw[funYellow!80, line width=1.5pt]
            ([xshift=3cm, yshift=-8.2cm]current page.north west) --
            ([xshift=-3cm, yshift=-8.2cm]current page.north east);
        %
        % ============ DESCRIPTION BOX ============
        \node[anchor=north, inner sep=0pt] at ([yshift=-12cm]current page.north) {%
            \begin{minipage}{0.78\textwidth}%
            \begin{tcolorbox}[
                enhanced,
                colback=white,
                colframe=funOrange!25,
                colbacktitle=funOrange!65,
                coltitle=white,
                fonttitle=\large\bfseries\sffamily,
                title={\faBookOpen\hspace{3mm}Today You Will Learn\hspace{3mm}\faBookOpen},
                halign title=center,
                arc=10pt,
                outer arc=10pt,
                boxrule=1.5pt,
                width=\textwidth,
                top=6mm, bottom=6mm,
                left=10mm, right=10mm,
                toptitle=4mm, bottomtitle=4mm,
                shadow={2mm}{-2mm}{0mm}{funOrange!8},
            ]
                \sffamily\normalsize
                #3
            \end{tcolorbox}%
            \end{minipage}%
        };%
        %
        % ============ PROGRESS INDICATOR ============
        % Mini progress bar at bottom
        \pgfmathsetmacro{\progresswidth}{0.6 * \textwidth / 1cm}
        \pgfmathsetmacro{\filledwidth}{\progresswidth * #1 / 30}
        %
        \node[anchor=south, inner sep=0pt] at ([yshift=5cm]current page.south) {%
            \begin{minipage}{0.6\textwidth}%
            \begin{center}
                {\sffamily\small\color{funGray}\faChartBar\hspace{2mm}Your Progress: Day #1 of 30}\\[4pt]
                \begin{tikzpicture}
                    % Background bar
                    \fill[funGrayLight, rounded corners=4pt]
                        (0,0) rectangle (\progresswidth cm, 0.5cm);
                    % Filled portion
                    \fill[funOrange!80, rounded corners=4pt]
                        (0,0) rectangle (\filledwidth cm, 0.5cm);
                    % Percentage text
                    \pgfmathsetmacro{\pct}{round(#1 / 30 * 100)}
                    \node[font=\sffamily\scriptsize\bfseries\color{white}] 
                        at (\filledwidth/2 cm, 0.25cm) {\pgfmathprintnumber[assume math mode=true]{\pct}\%};
                \end{tikzpicture}
            \end{center}
            \end{minipage}%
        };%
        %
        % ============ MOTIVATIONAL TEXT ============
        \node[
            font=\sffamily\normalsize\color{funOrangeDark},
        ] at ([yshift=3.5cm]current page.south)
            {Ready to begin?\hspace{2mm}\faArrowRight};
        %
    \end{tikzpicture}%
    %
    \newpage
}

