%----------------------------------------------------------------------------------------
% PROGRESS TRACKER — Full 30-day visual tracker (for initial pages)
%   Draws a 5×6 grid of day boxes (weeks × days)
%----------------------------------------------------------------------------------------
\newcommand{\progressTracker}{%
    \begin{center}
    \begin{tcolorbox}[
        enhanced,
        colback=white,
        colframe=funOrange!40,
        colbacktitle=funOrange!70,
        coltitle=white,
        fonttitle=\Large\bfseries\sffamily,
        title={\faIcon{calendar-alt}\hspace{3mm}My 30-Day Progress\hspace{3mm}\faIcon{calendar-alt}},
        halign title=center,
        arc=10pt,
        outer arc=10pt,
        boxrule=1.5pt,
        width=0.9\linewidth,
        top=6mm, bottom=6mm,
        left=6mm, right=6mm,
        toptitle=4mm, bottomtitle=4mm,
    ]
        \centering\sffamily
        \begin{tikzpicture}[
            daybox/.style={
                rectangle, rounded corners=4pt,
                minimum width=2.4cm, minimum height=1.5cm,
                draw=funOrange!40, line width=0.8pt,
                fill=funOrangeLight,
                font=\sffamily\small,
                align=center,
            },
        ]
        \foreach \row in {0,...,4} {
            \foreach \col in {0,...,5} {
                \pgfmathtruncatemacro{\daynum}{\row * 6 + \col + 1}
                \ifnum\daynum<31
                    \node[daybox] at (\col * 2.7, -\row * 1.8)
                        {\textbf{\color{funOrangeDark}Day \daynum}\\[1pt]
                         {\scriptsize\color{funGray}\faSquare}};
                \fi
            }
        }
        \end{tikzpicture}
        \vspace{4mm}

        {\small\color{funGrayDark}
            \faCheckSquare\ = Done \hspace{6mm}
            Check off each day as you complete it.
        }
    \end{tcolorbox}
    \end{center}
}

%----------------------------------------------------------------------------------------
% MINUTE TIMER — Shows estimated minutes for a section
