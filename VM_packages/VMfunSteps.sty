    arc=6pt,
    outer arc=6pt,
    boxrule=1.5pt,
    top=5mm,
    bottom=5mm,
    left=6mm,
    right=6mm,
    toptitle=3mm,
    bottomtitle=3mm,
    before skip=8pt,
    after skip=8pt,
    breakable,
}

%========================================================================================
% 6. PRACTICE SECTION — Problems for independent work
%========================================================================================
\newtcolorbox{stepPractice}[2][funBlue]{
