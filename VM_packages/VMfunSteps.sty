%----------------------------------------------------------------------------------------
% VMfunSteps.sty - Step-by-Step Environments for Grade 7 (v2)
% Design: Show ALL steps first as a concise procedure, then worked examples
% applying those steps. Clean, focused, minimal decoration.
%----------------------------------------------------------------------------------------
\ProvidesPackage{VMfunSteps}[2026/03/02 Grade 7 Step-by-Step Environments v2]

%========================================================================================
% STEP COLOR PALETTE — Each step gets its own color
%========================================================================================
\definecolor{step1Color}{HTML}{2196F3}    % Blue
\definecolor{step1Dark}{HTML}{1565C0}
\definecolor{step1Light}{HTML}{E3F2FD}
\definecolor{step2Color}{HTML}{4CAF50}    % Green
\definecolor{step2Dark}{HTML}{2E7D32}
\definecolor{step2Light}{HTML}{E8F5E9}
\definecolor{step3Color}{HTML}{FF9800}    % Orange
\definecolor{step3Dark}{HTML}{E65100}
\definecolor{step3Light}{HTML}{FFF3E0}
\definecolor{step4Color}{HTML}{9C27B0}    % Purple
\definecolor{step4Dark}{HTML}{6A1B9A}
\definecolor{step4Light}{HTML}{F3E5F5}
\definecolor{step5Color}{HTML}{00BCD4}    % Cyan
\definecolor{step5Dark}{HTML}{00838F}
\definecolor{step5Light}{HTML}{E0F7FA}
\definecolor{step6Color}{HTML}{FF5722}    % Deep Orange
\definecolor{step6Dark}{HTML}{D84315}
\definecolor{step6Light}{HTML}{FBE9E7}

% Steps card accent
\definecolor{stepsCardBg}{HTML}{F8F9FA}       % Very light gray
\definecolor{stepsCardBorder}{HTML}{1A237E}   % Dark indigo

% Helper to get step color by number
\newcommand{\getStepColor}[1]{%
    \ifcase#1\relax funBlue%
    \or step1Color\or step2Color\or step3Color%
    \or step4Color\or step5Color\or step6Color%
    \else funBlue\fi
}
\newcommand{\getStepDark}[1]{%
    \ifcase#1\relax funBlueDark%
    \or step1Dark\or step2Dark\or step3Dark%
    \or step4Dark\or step5Dark\or step6Dark%
    \else funBlueDark\fi
}
\newcommand{\getStepLight}[1]{%
    \ifcase#1\relax funBlueLight%
    \or step1Light\or step2Light\or step3Light%
    \or step4Light\or step5Light\or step6Light%
    \else funBlueLight\fi
}

%========================================================================================
% 1. STEP-BY-STEP TITLE — Clean banner
%========================================================================================
\newcommand{\stepByStepTitle}[1]{%
    \begin{center}
    \begin{tcolorbox}[
        enhanced,
        colback=stepsCardBg,
        colframe=stepsCardBorder,
        boxrule=2pt,
        arc=10pt,
        outer arc=10pt,
        top=5mm,
        bottom=5mm,
        left=8mm,
        right=8mm,
        width=0.88\linewidth,
        halign=center,
        fontupper=\Huge\bfseries\sffamily\color{stepsCardBorder},
    ]
        #1%
    \end{tcolorbox}
    \end{center}
    \vspace{0.5mm}
    \begin{center}
        {\sffamily\bfseries\color{stepsCardBorder}\faRoute\hspace{2mm}%
        Step-by-Step Guide\hspace{2mm}\faRoute}
    \end{center}
    \vspace{3mm}
}

%========================================================================================
% 2. STEP GOAL — Brief learning objectives
%========================================================================================
\newtcolorbox{stepGoal}{
    enhanced,
    colback=step1Light,
    colframe=step1Color,
    boxrule=1.5pt,
    arc=6pt,
    outer arc=6pt,
    top=4mm,
    bottom=4mm,
    left=6mm,
    right=6mm,
    before skip=6pt,
    after skip=8pt,
    fontupper=\sffamily,
    title={\large\bfseries\sffamily\color{white}What You'll Learn},
    colbacktitle=step1Color,
    coltitle=white,
    toptitle=2.5mm,
    bottomtitle=2.5mm,
}

%========================================================================================
% 3. STEPS CARD — Lists ALL steps as a concise numbered procedure
%    This is the centerpiece of every topic. Shown once, up front.
%========================================================================================
\newcounter{stepCardNum}[section]

\newenvironment{stepsCard}[1][The Steps]{%
    \setcounter{stepCardNum}{0}%
    \par\vspace{4mm}%
    \begin{tcolorbox}[
        enhanced,
        colback=stepsCardBg,
        colframe=stepsCardBorder,
        boxrule=2pt,
        arc=8pt,
        outer arc=8pt,
        top=5mm,
        bottom=6mm,
        left=8mm,
        right=8mm,
        before skip=10pt,
        after skip=12pt,
        title={\faListOl\hspace{3mm}#1},
        halign title=center,
        colbacktitle=stepsCardBorder,
        coltitle=white,
        fonttitle=\large\bfseries\sffamily,
        toptitle=4mm,
        bottomtitle=4mm,
    ]
}{%
    \end{tcolorbox}%
    \vspace{2mm}%
}

% Individual step inside stepsCard
\newcommand{\stepItem}[1]{%
    \stepcounter{stepCardNum}%
    \par\vspace{3mm}\noindent
    \tikz[baseline=-0.3ex]{%
        \node[circle, fill=\getStepColor{\value{stepCardNum}},
              text=white, inner sep=0pt, minimum size=0.7cm,
              font=\normalsize\bfseries\sffamily]
            {\thestepCardNum};
    }%
    \hspace{4mm}{\normalsize\sffamily #1}%
    \par
}

%========================================================================================
% 4. WORKED EXAMPLE — Shows ALL steps applied to one problem
%========================================================================================
\newtcolorbox{stepExample}[1]{
    enhanced,
    colback=white,
    colframe=funOrange,
    colbacktitle=funOrange,
    coltitle=white,
    fonttitle=\large\bfseries\sffamily,
    title={Example: #1},
    arc=6pt,
    outer arc=6pt,
    boxrule=1.5pt,
    top=5mm,
    bottom=5mm,
    left=6mm,
    right=6mm,
    toptitle=3mm,
    bottomtitle=3mm,
    before skip=8pt,
    after skip=8pt,
    breakable,
}

% Label which step is being applied inside a worked example
\newcommand{\stepShow}[1]{%
    \par\vspace{3mm}\noindent
    \tikz[baseline=-0.3ex]{%
        \node[rounded corners=3pt, fill=\getStepColor{#1},
              text=white, inner xsep=5pt, inner ysep=2pt,
              font=\small\bfseries\sffamily, minimum height=0.45cm]
            {Step #1};
    }%
    \hspace{3mm}%
}

% Final answer in a worked example
\newcommand{\stepResult}[1]{%
    \par\vspace{4mm}
    \begin{center}
    \tikz{
        \node[rounded corners=5pt, fill=funGreen!12,
              draw=funGreen, line width=1.2pt,
              inner sep=7pt,
              text width=0.82\linewidth,
              align=center,
              font=\large\sffamily\bfseries\color{funGreenDark}]
            {\faCheck\hspace{3mm}#1};
    }
    \end{center}
    \vspace{1mm}
}

%========================================================================================
% 5. YOUR TURN — Guided practice where student applies steps with blanks
%========================================================================================
\newtcolorbox{stepTryIt}[1]{
    enhanced,
    colback=funYellow!5,
