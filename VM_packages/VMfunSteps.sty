    top=5mm,
    bottom=5mm,
    left=5mm,
    right=5mm,
    toptitle=4mm,
    bottomtitle=4mm,
    before skip=10pt,
    after skip=8pt,
    breakable,
}

% Practice sub-header (labels a group of problems)
\newcommand{\stepPracticeHeader}[2][funBlue]{%
    \par\vspace{4mm}%
    \begin{tcolorbox}[
        enhanced,
        colback=#1!10,
        colframe=#1,
        boxrule=1pt,
        arc=4pt,
        outer arc=4pt,
        left=4mm,
        right=4mm,
        top=2mm,
        bottom=2mm,
    ]
        {\bfseries\sffamily\color{#1!80!black}#2}
