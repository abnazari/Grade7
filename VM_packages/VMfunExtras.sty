%========================================================================================
% 10. CONVERSATION BUBBLES (for dialogues between characters)
%     Usage: \sayLeft{mascot}{I have 12 cookies!}
%            \sayRight{student}{How do we share them with 3 friends?}
%========================================================================================
\newcommand{\sayLeft}[2]{%
    \par\vspace{2mm}\noindent
    \begin{minipage}[t]{0.12\linewidth}
        \centering{\color{funBlue}\faComment}\\[1mm]\small\sffamily\bfseries #1
    \end{minipage}%
    \begin{minipage}[t]{0.55\linewidth}
        \begin{tcolorbox}[
            enhanced,
            colback=funBlueLight,
            colframe=funBlue!40,
            boxrule=1pt,
            arc=8pt,
            left=3mm, right=3mm,
            top=2mm, bottom=2mm,
        ]
            \sffamily #2
        \end{tcolorbox}
    \end{minipage}%
    \par\vspace{1mm}%
}

\newcommand{\sayRight}[2]{%
    \par\vspace{1mm}%
    \hfill
    \begin{minipage}[t]{0.55\linewidth}
        \begin{tcolorbox}[
            enhanced,
            colback=funGreenLight,
            colframe=funGreen!40,
            boxrule=1pt,
            arc=8pt,
            left=3mm, right=3mm,
            top=2mm, bottom=2mm,
        ]
            \sffamily #2
        \end{tcolorbox}
    \end{minipage}%
    \begin{minipage}[t]{0.12\linewidth}
        \centering{\color{funGreen}\faComment}\\[1mm]\small\sffamily\bfseries #1
    \end{minipage}%
    \par\vspace{2mm}%
}

