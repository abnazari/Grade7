    colback=funRedLight,
    colframe=funRed,
    colbacktitle=funRed!15,
    coltitle=funRed!80!black,
    fonttitle=\large\bfseries\sffamily,
    title={\iconWarning~~#1},
    arc=8pt,
    outer arc=8pt,
    boxrule=1.5pt,
    top=5mm, bottom=5mm,
    left=5mm, right=5mm,
    toptitle=3mm, bottomtitle=3mm,
    before skip=8pt, after skip=8pt,
    breakable,
}

