%----------------------------------------------------------------------------------------
% VMfunExtras.sty - Extra Elements for Grade 7
% Includes: Mascot, Tips, Fun Facts, Warnings, Think About It, Notes
%----------------------------------------------------------------------------------------
\ProvidesPackage{VMfunExtras}[2026/03/02 Grade 7 Extra Elements]

%========================================================================================
% 1. MASCOT SAYS (Owl character with speech bubble)
%    An owl mascot gives tips, encouragement, or fun explanations.
%    Design: Owl icon on the left, purple speech bubble on the right.
%    Usage: \mascotSays{Division = fair sharing! Split things into equal groups.}
%========================================================================================
\newcommand{\mascotSays}[1]{%
    \par\vspace{4mm}%
    \noindent
    \begin{minipage}[c]{0.1\linewidth}
        \centering
        \iconOwl[1.4cm]
    \end{minipage}%
    \hfill
    \begin{minipage}[c]{0.85\linewidth}
        \begin{tcolorbox}[
            enhanced,
            colback=funPurple!8,
            colframe=funPurple!50,
            boxrule=1.5pt,
            arc=10pt,
            outer arc=10pt,
            left=5mm, right=5mm,
            top=3mm, bottom=3mm,
            fontupper=\itshape\sffamily,
            before upper={\color{funPurpleDark}\faQuoteLeft~},
            after upper={~\color{funPurpleDark}\faQuoteRight},
        ]
            #1
        \end{tcolorbox}
    \end{minipage}%
    \par\vspace{4mm}%
}

%========================================================================================
% 2. TIP BOX (Pencil character with helpful tip)
%    A pencil character gives a useful tip or trick.
%    Design: Pencil icon + cream/yellow dotted-border speech bubble.
%    Usage: \tipBox{Line up your numbers by place value!}
%========================================================================================
\newcommand{\tipBox}[1]{%
    \par\vspace{4mm}%
    \noindent
    \begin{minipage}[c]{0.08\linewidth}
        \centering
        \iconPencil[1.2cm]
    \end{minipage}%
    \hfill
    \begin{minipage}[c]{0.88\linewidth}
        \begin{tcolorbox}[
            enhanced,
            colback=funYellowLight,
            colframe=funYellow,
            boxrule=0pt,
            borderline={1.5pt}{0pt}{funOrange, dashed},
            arc=10pt,
            outer arc=10pt,
            left=5mm, right=5mm,
            top=3mm, bottom=3mm,
            fontupper=\sffamily,
            overlay={
                \node[anchor=north west, fill=funOrange, text=white, rounded corners=3pt,
                      inner sep=2pt, font=\tiny\bfseries\sffamily]
                    at ([xshift=3mm, yshift=-1mm]frame.north west) {\faInfoCircle~TIP};
            },
        ]
            \vspace{1mm}#1
        \end{tcolorbox}
    \end{minipage}%
    \par\vspace{4mm}%
}

%========================================================================================
% 3. FUN FACT BOX
%    An interesting math fact to engage students.
%    Design: Pink/yellow box with lightbulb icon.
%    Usage: \begin{funFact} Did you know that... \end{funFact}
%========================================================================================
\newtcolorbox{funFact}{
    enhanced,
    colback=funPinkLight,
    colframe=funPink,
    colbacktitle=funPink!15,
    coltitle=funPinkDark,
    fonttitle=\large\bfseries\sffamily,
    title={\iconLightbulb~~Fun Fact!},
    arc=8pt,
    outer arc=8pt,
    boxrule=1.5pt,
    top=4mm, bottom=4mm,
    left=5mm, right=5mm,
    toptitle=3mm, bottomtitle=3mm,
    before skip=8pt, after skip=8pt,
    breakable,
}

%========================================================================================
% 4. WARNING BOX (Common Mistakes)
