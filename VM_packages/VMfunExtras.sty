%    Usage: \begin{warningBox} Don't forget to carry! \end{warningBox}
%    Optional title: \begin{warningBox}[Common Mistake!] ... \end{warningBox}
%========================================================================================
\newtcolorbox{warningBox}[1][Watch Out!]{
