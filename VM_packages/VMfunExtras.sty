%========================================================================================
% 6. ENCOURAGEMENT BANNER
%    A motivational message to encourage students.
%    Design: Colorful gradient-like banner with fun text.
%    Usage: \encouragement{Great job! You're a math superstar!}
%========================================================================================
\newcommand{\encouragement}[1]{%
    \par\vspace{4mm}%
    \begin{center}
    \begin{tcolorbox}[
        enhanced,
        colback=funYellow!15,
        colframe=funYellow,
        boxrule=2pt,
        arc=12pt,
        outer arc=12pt,
        width=0.92\linewidth,
        halign=center,
        top=4mm, bottom=4mm,
        left=8mm, right=8mm,
        fontupper=\large\bfseries\sffamily\color{funOrangeDark},
    ]
        #1
    \end{tcolorbox}
    \end{center}
    \vspace{2mm}%
}

%========================================================================================
% 7. DID YOU KNOW? (Quick interesting tidbit)
%    A shorter version of Fun Fact for quick facts.
%    Usage: \didYouKnow{Zero is neither odd nor even!}
%========================================================================================
\newcommand{\didYouKnow}[1]{%
    \par\vspace{3mm}%
    \noindent
    \begin{tcolorbox}[
        enhanced,
        colback=funYellowLight,
        colframe=funYellow!70,
        boxrule=1pt,
        arc=6pt,
        outer arc=6pt,
        left=5mm, right=5mm,
        top=3mm, bottom=3mm,
    ]
        {\color{funYellowDark}\faLightbulb[regular]}~{\bfseries\sffamily\color{funYellowDark}Did you know?}\hspace{3mm}#1
    \end{tcolorbox}
    \vspace{2mm}%
}

