\ansChap{1}
\ansSec{1.1}
\ansItem{1}{$2$ walls per hour}
\ansExplain{1}{$\frac {2}{3} \div \frac {1}{3} = \frac {2}{3} \times 3 = 2$}
\ansItem{2}{$\frac {2}{3}$ cup per minute}
\ansExplain{2}{$\frac {1}{2} \div \frac {3}{4} = \frac {1}{2} \times \frac {4}{3} = \frac {2}{3}$}
\ansItem{3}{$1\frac {1}{4}$ gallons per mile}
\ansExplain{3}{$\frac {5}{6} \div \frac {2}{3} = \frac {5}{6} \times \frac {3}{2} = \frac {5}{4}$}
\ansItem{4}{Equal --- both $2$ cups per cup}
\ansExplain{4}{A: $\frac {1}{2} \div \frac {1}{4} = 2$. B: $\frac {2}{3} \div \frac {1}{3} = 2$.}
\ansItem{5}{Beetle: $\frac {7}{8}$ m/hr $>$ $\frac {5}{6}$ m/hr}
\ansExplain{5}{Snail: $\frac {5}{8} \div \frac {3}{4} = \frac {5}{6}$. Beetle: $\frac {7}{10} \div \frac {4}{5} = \frac {7}{8}$.}
\ansSec{1.2}
\ansItem{1}{Yes}
\ansExplain{1}{$9 \div 3 = 3$, $15 \div 5 = 3$, $21 \div 7 = 3$. All ratios equal.}
\ansItem{2}{No}
\ansExplain{2}{$6 \div 2 = 3$, $10 \div 4 = 2.5$, $14 \div 6 \approx 2.3$. Ratios differ.}
\ansItem{3}{True}
\ansItem{4}{Plan 1}
\ansExplain{4}{No base fee → cost $= 0.05 \times \text {texts}$, always the same ratio. Plan 2's $\$5$ base breaks it.}
\ansSec{1.3}
\ansItem{1}{$k = 4$}
\ansItem{2}{$k = 60$ miles per hour}
\ansExplain{2}{$30 \div \frac {1}{2} = 60$}
\ansItem{3}{$k = 2.5$}
\ansExplain{3}{$15 \div 6 = 2.5$}
\ansItem{4}{$k = 16$ pages/min}
\ansExplain{4}{$80 \div 5 = 16$}
\ansItem{5}{$y = 21$}
\ansExplain{5}{$k = 14 \div 4 = 3.5$, so $y = 3.5 \times 6 = 21$}
\ansSec{1.4}
\ansItem{1}{$c = 8h$}
\ansItem{2}{$g = 3.5m$}
\ansItem{3}{$y = 2.5x$}
\ansExplain{3}{$k = 10 \div 4 = 2.5$}
\ansItem{4}{$9$ cups}
\ansExplain{4}{$f = \frac {3}{4}s$; $f = \frac {3}{4} \times 12 = 9$}
\ansItem{5}{$250$ texts}
\ansExplain{5}{$c = 0.04t$; $10 = 0.04t$; $t = 250$}
\ansSec{1.5}
\ansItem{1}{One ticket costs $\$5$}
\ansExplain{1}{$(1, r)$ gives the unit rate.}
\ansItem{2}{Unit rate $= 6$; $y = 42$}
\ansExplain{2}{$k = 18 \div 3 = 6$. $y = 6 \times 7 = 42$.}
\ansItem{3}{Runner A}
\ansExplain{3}{A: $k = 5$. B: $k = 4$. Steeper line = faster.}
\ansItem{4}{False}
\ansItem{5}{$y = 2.5x$; $x = 16$}
\ansExplain{5}{$k = 2.5$. $40 = 2.5x$, so $x = 16$.}
\ansSec{1.6}
\ansItem{1}{$350$ miles}
\ansExplain{1}{$210 \div 6 = 35$ mpg. $35 \times 10 = 350$.}
\ansItem{2}{$3\frac {3}{4}$ cups}
\ansExplain{2}{$k = \frac {3}{2} \div 4 = \frac {3}{8}$. $\frac {3}{8} \times 10 = \frac {30}{8} = 3\frac {3}{4}$.}
\ansItem{3}{$64$ km}
\ansExplain{3}{$\frac {3}{24} = \frac {8}{d}$; $d = 64$.}
\ansItem{4}{$30$ min}
\ansExplain{4}{$120 \div 8 = 15$ pages/min. $450 \div 15 = 30$.}
\ansItem{5}{Large by $\$2$/gal}
\ansExplain{5}{Small: $18 \div 0.75 = \$24$/gal. Large: $33 \div 1.5 = \$22$/gal.}
