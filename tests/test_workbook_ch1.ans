\ansChap{1}
\ansSec{1.1}
\ansItem{1}{$30$ miles per hour}
\ansExplain{1}{To find the unit rate, divide the total distance by the total time: $120 \div 4 = 30$ miles per hour.}
\ansItem{2}{$\$9$ per shirt}
\ansExplain{2}{Divide total cost by the number of shirts: $45 \div 5 = 9$. Each shirt costs $\$9$.}
\ansItem{3}{$12$ pages per day}
\ansExplain{3}{Divide total pages by the number of days: $84 \div 7 = 12$ pages per day.}
\ansItem{4}{$5$ apples per bag}
\ansExplain{4}{Divide the total by the number of groups: $60 \div 12 = 5$ apples per bag.}
\ansItem{5}{$\$4$ per gallon}
\ansExplain{5}{Divide total cost by gallons: $32 \div 8 = 4$. Each gallon costs $\$4$.}
\ansItem{6}{$40$ words per minute}
\ansExplain{6}{Divide total words by minutes: $200 \div 5 = 40$ words per minute.}
\ansItem{7}{$2$ cups per batch}
\ansExplain{7}{Divide cups by batches: $\frac {2}{3} \div \frac {1}{3} = \frac {2}{3} \times \frac {3}{1} = \frac {6}{3} = 2$ cups per batch.}
\ansItem{8}{$1\frac {1}{2}$ buckets per minute}
\ansExplain{8}{Divide buckets by minutes: $\frac {3}{4} \div \frac {1}{2} = \frac {3}{4} \times \frac {2}{1} = \frac {6}{4} = \frac {3}{2} = 1\frac {1}{2}$ buckets per minute.}
\ansItem{9}{$1\frac {1}{4}$ miles per minute}
\ansExplain{9}{Divide distance by time: $\frac {5}{6} \div \frac {2}{3} = \frac {5}{6} \times \frac {3}{2} = \frac {15}{12} = \frac {5}{4} = 1\frac {1}{4}$ miles per minute.}
\ansItem{10}{$2$ kg per hour}
\ansExplain{10}{Divide kg by hours: $\frac {4}{5} \div \frac {2}{5} = \frac {4}{5} \times \frac {5}{2} = \frac {20}{10} = 2$ kg per hour.}
\ansItem{11}{$1\frac {1}{6}$ rows per hour}
\ansExplain{11}{Divide rows by hours: $\frac {7}{8} \div \frac {3}{4} = \frac {7}{8} \times \frac {4}{3} = \frac {28}{24} = \frac {7}{6} = 1\frac {1}{6}$ rows per hour.}
\ansItem{12}{$\frac {2}{5}$ cup per batch}
\ansExplain{12}{Divide cups by batches: $\frac {1}{3} \div \frac {5}{6} = \frac {1}{3} \times \frac {6}{5} = \frac {6}{15} = \frac {2}{5}$ cup per batch.}
\ansItem{13}{Runner B ($2\frac {1}{2}$ mph $>$ $2\frac {2}{5}$ mph)}
\ansExplain{13}{Runner A: $\frac {3}{5} \div \frac {1}{4} = \frac {3}{5} \times 4 = \frac {12}{5} = 2\frac {2}{5}$ mph. Runner B: $\frac {5}{6} \div \frac {1}{3} = \frac {5}{6} \times 3 = \frac {15}{6} = 2\frac {1}{2}$ mph. Since $2\frac {1}{2} = 2.5 > 2\frac {2}{5} = 2.4$, Runner B is faster.}
\ansItem{14}{Brand Y ($\$3$/lb $<$ $\$3\frac {1}{3}$/lb)}
\ansExplain{14}{Brand X: $\frac {5}{2} \div \frac {3}{4} = \frac {5}{2} \times \frac {4}{3} = \frac {20}{6} = \$3\frac {1}{3}$ per lb. Brand Y: $2 \div \frac {2}{3} = 2 \times \frac {3}{2} = \$3$ per lb. Brand Y is cheaper.}
\ansItem{15}{Pipe B ($1\frac {1}{2}$ tanks/hr $>$ $1\frac {1}{4}$ tanks/hr)}
\ansExplain{15}{Pipe A: $\frac {1}{2} \div \frac {2}{5} = \frac {1}{2} \times \frac {5}{2} = \frac {5}{4} = 1\frac {1}{4}$ tanks/hr. Pipe B: $\frac {3}{4} \div \frac {1}{2} = \frac {3}{4} \times 2 = \frac {3}{2} = 1\frac {1}{2}$ tanks/hr. Pipe B fills faster.}
\ansItem{16}{Cyclist A ($3\frac {1}{2}$ mph $>$ $3\frac {1}{5}$ mph)}
\ansExplain{16}{Cyclist A: $\frac {7}{10} \div \frac {1}{5} = \frac {7}{10} \times 5 = \frac {35}{10} = 3\frac {1}{2}$ mph. Cyclist B: $\frac {4}{5} \div \frac {1}{4} = \frac {4}{5} \times 4 = \frac {16}{5} = 3\frac {1}{5}$ mph. Cyclist A is faster.}
\ansItem{17}{False}
\ansExplain{17}{To find a unit rate, you \emph {divide} the first quantity by the second. Dividing fractions uses Keep--Change--Flip (multiply by the reciprocal), but the operation is division, not just multiplication.}
\ansItem{18}{True}
\ansExplain{18}{Keep--Change--Flip: $\frac {2}{3} \times \frac {6}{1} = \frac {12}{3} = 4$. The statement is correct.}
\ansItem{19}{False}
\ansExplain{19}{Divide distance by time: $\frac {1}{2} \div \frac {1}{4} = \frac {1}{2} \times 4 = 2$ miles per hour, not $\frac {1}{8}$. Multiplying $\frac {1}{2} \times \frac {1}{4} = \frac {1}{8}$ is the wrong operation.}
\ansItem{20}{$\frac {8}{15}$ of the fence}
\ansExplain{20}{Find the unit rate: $\frac {2}{5} \div \frac {3}{4} = \frac {2}{5} \times \frac {4}{3} = \frac {8}{15}$ of the fence per hour.}
\ansItem{21}{$1\frac {1}{4}$ bottles per second}
\ansExplain{21}{Divide bottles by seconds: $\frac {5}{6} \div \frac {2}{3} = \frac {5}{6} \times \frac {3}{2} = \frac {15}{12} = \frac {5}{4} = 1\frac {1}{4}$ bottles per second.}
\ansItem{22}{Emma is faster by $\frac {1}{2}$ chapter per hour}
\ansExplain{22}{Sam: $\frac {3}{4} \div \frac {1}{2} = \frac {3}{4} \times 2 = \frac {3}{2} = 1\frac {1}{2}$ ch/hr. Emma: $\frac {2}{3} \div \frac {1}{3} = \frac {2}{3} \times 3 = 2$ ch/hr. Difference: $2 - 1\frac {1}{2} = \frac {1}{2}$ chapter per hour.}
\ansItem{23}{Snail: $\frac {9}{20}$ m/hr $=$ Turtle: $\frac {7}{15}$ m/hr; Turtle is faster by $\frac {1}{60}$ m/hr}
\ansExplain{23}{Snail: $\frac {3}{8} \div \frac {5}{6} = \frac {3}{8} \times \frac {6}{5} = \frac {18}{40} = \frac {9}{20}$ m/hr. Turtle: $\frac {7}{12} \div \frac {5}{4} = \frac {7}{12} \times \frac {4}{5} = \frac {28}{60} = \frac {7}{15}$ m/hr. Compare: $\frac {9}{20} = \frac {27}{60}$ and $\frac {7}{15} = \frac {28}{60}$. The turtle is faster by $\frac {1}{60}$ m/hr.}
\ansItem{24}{Machine A ($2\frac {2}{9}$ widgets/hr $>$ $2$ widgets/hr)}
\ansExplain{24}{Machine A: $\frac {5}{6} \div \frac {3}{8} = \frac {5}{6} \times \frac {8}{3} = \frac {40}{18} = \frac {20}{9} = 2\frac {2}{9}$ widgets/hr. Machine B: $\frac {4}{3} \div \frac {2}{3} = \frac {4}{3} \times \frac {3}{2} = \frac {12}{6} = 2$ widgets/hr. Machine A is more productive.}
\ansSec{1.2}
\ansItem{1}{$3$}
\ansExplain{1}{Divide $y$ by $x$: $12 \div 4 = 3$.}
\ansItem{2}{$4$}
\ansExplain{2}{Divide $y$ by $x$: $20 \div 5 = 4$.}
\ansItem{3}{$2.5$}
\ansExplain{3}{Divide $y$ by $x$: $7.5 \div 3 = 2.5$.}
\ansItem{4}{$3$}
\ansExplain{4}{Divide $y$ by $x$: $18 \div 6 = 3$.}
\ansItem{5}{$2.5$}
\ansExplain{5}{Divide $y$ by $x$: $25 \div 10 = 2.5$.}
\ansItem{6}{$4$}
\ansExplain{6}{Divide $y$ by $x$: $32 \div 8 = 4$.}
\ansItem{7}{Proportional}
\ansExplain{7}{Ratios: $8 \div 2 = 4$, $20 \div 5 = 4$, $36 \div 9 = 4$. Every ratio equals $4$, so the relationship is proportional.}
\ansItem{8}{Not proportional}
\ansExplain{8}{Ratios: $9 \div 3 = 3$, $11 \div 4 = 2.75$, $15 \div 6 = 2.5$. The ratios are not equal, so it is not proportional.}
\ansItem{9}{Proportional}
\ansExplain{9}{Ratios: $6 \div 4 = 1.5$, $12 \div 8 = 1.5$, $18 \div 12 = 1.5$. Every ratio equals $1.5$, so the relationship is proportional.}
\ansItem{10}{Not proportional}
\ansExplain{10}{Ratios: $5 \div 1 = 5$, $8 \div 2 = 4$, $11 \div 3 \approx 3.67$. The ratios differ. The pattern adds $3$ each time (constant change) but that does not make a constant ratio.}
\ansItem{11}{Proportional}
\ansExplain{11}{Ratios: $3 \div \frac {1}{2} = 6$, $6 \div 1 = 6$, $12 \div 2 = 6$. Every ratio equals $6$, so it is proportional.}
\ansItem{12}{False}
\ansExplain{12}{A proportional relationship requires the \emph {same} ratio $y \div x$ for every pair. Even one different ratio means it is not proportional.}
\ansItem{13}{True}
\ansExplain{13}{A proportional relationship graphs as a straight line that passes through the origin. Both conditions (straight line and through the origin) are needed, and both are satisfied here.}
\ansItem{14}{False}
\ansExplain{14}{A proportional equation has the form $y = kx$ with no added constant. The $+2$ means the line does not pass through $(0, 0)$, so it is not proportional.}
\ansItem{15}{False}
\ansExplain{15}{A proportional graph must pass through the origin $(0, 0)$. A $y$-intercept of $4$ means it does not start at zero, so the relationship is not proportional.}
\ansItem{16}{Yes}
\ansExplain{16}{With no sign-up fee, cost $= 25 \times $ months. Every month costs the same per-month amount, and $0$ months costs $\$0$. The ratio is always $25$, so it is proportional.}
\ansItem{17}{No}
\ansExplain{17}{The $\$3$ flat fee means a $0$-mile ride costs $\$3$, not $\$0$. The ratio changes with each mile (e.g., $5/1 = 5$, $7/2 = 3.5$), so it is not proportional.}
\ansItem{18}{Yes}
\ansExplain{18}{Each pen costs the same amount, there is no extra fee, and $0$ pens cost $\$0$. The ratio is always $0.50$, so cost is proportional to the number of pens.}
\ansItem{19}{No}
\ansExplain{19}{The $\$10$ base fee does not depend on texts. At $0$ texts the bill is $\$10$, not $\$0$. The per-text ratio changes, so the relationship is not proportional.}
\ansItem{20}{$y = 15$}
\ansExplain{20}{Check the ratio: $6 \div 2 = 3$, $12 \div 4 = 3$, $24 \div 8 = 3$. All ratios equal $3$, so it is proportional with $k = 3$. The missing value is $y = 3 \times 5 = 15$.}
\ansItem{21}{Answers vary; e.g., $(1,2), (3,6), (4,9), (5,11)$}
\ansExplain{21}{The first two rows give $2 \div 1 = 2$ and $6 \div 3 = 2$, but the third or fourth row has a different ratio (e.g., $9 \div 4 = 2.25$). One mismatched ratio is enough to make the whole relationship not proportional.}
\ansSec{1.3}
\ansItem{1}{$k = 5$}
\ansExplain{1}{Divide $y$ by $x$: $10 \div 2 = 5$.}
\ansItem{2}{$k = 7$}
\ansExplain{2}{Divide $y$ by $x$: $28 \div 4 = 7$.}
\ansItem{3}{$k = 2.5$}
\ansExplain{3}{Divide $y$ by $x$: $12.5 \div 5 = 2.5$.}
\ansItem{4}{$k = 1.5$}
\ansExplain{4}{Divide $y$ by $x$: $4.5 \div 3 = 1.5$.}
\ansItem{5}{$k = 0.75$}
\ansExplain{5}{Divide $y$ by $x$: $6 \div 8 = 0.75$.}
\ansItem{6}{$k = 8$}
\ansExplain{6}{Divide $y$ by $x$: $4 \div \frac {1}{2} = 4 \times 2 = 8$.}
\ansItem{7}{$k = 2.50$; each cupcake costs $\$2.50$}
\ansExplain{7}{Pick any row: $7.50 \div 3 = 2.50$. Check: $12.50 \div 5 = 2.50$ and $20.00 \div 8 = 2.50$. The unit rate $k = 2.50$ means each cupcake costs $\$2.50$.}
\ansItem{8}{$k = 45$; the factory makes $45$ widgets per hour}
\ansExplain{8}{Divide: $90 \div 2 = 45$. Check: $180 \div 4 = 45$, $315 \div 7 = 45$. The constant of proportionality means the factory produces $45$ widgets every hour.}
\ansItem{9}{$k = 1.5$}
\ansExplain{9}{Divide: $9 \div 6 = 1.5$. Check: $15 \div 10 = 1.5$ and $21 \div 14 = 1.5$. All rows confirm $k = 1.5$.}
\ansItem{10}{$k = 6$}
\ansExplain{10}{Divide using the second row for simplicity: $6 \div 1 = 6$. Check: $2 \div \frac {1}{3} = 2 \times 3 = 6$ and $12 \div 2 = 6$. So $k = 6$.}
\ansItem{11}{$k = 5.5$}
\ansExplain{11}{On a proportional graph, $k = y \div x$: $22 \div 4 = 5.5$.}
\ansItem{12}{$k = 8$}
\ansExplain{12}{When $x = 1$, the $y$-value IS the unit rate. So $k = 8$.}
\ansItem{13}{$k = 35$ miles per gallon}
\ansExplain{13}{Divide distance by gallons: $210 \div 6 = 35$. The car gets $35$ miles per gallon.}
\ansItem{14}{$k = 12$ pages per minute}
\ansExplain{14}{Divide pages by time: $96 \div 8 = 12$ pages per minute.}
\ansItem{15}{$y = 9$}
\ansExplain{15}{Find $k$: $3 \div 5 = 0.6$. Then $y = 0.6 \times 15 = 9$. Alternatively, $x$ tripled from $5$ to $15$, so $y$ also triples: $3 \times 3 = 9$.}
\ansItem{16}{$y = 21$}
\ansExplain{16}{Find $k$: $14 \div 4 = 3.5$. Check: $35 \div 10 = 3.5$ \checkmark . Missing value: $y = 3.5 \times 6 = 21$.}
\ansItem{17}{$x = 7$}
\ansExplain{17}{Find $k$: $18 \div 3 = 6$. Check: $54 \div 9 = 6$ \checkmark . Missing value: $x = 42 \div 6 = 7$.}
\ansItem{18}{$y = 16$}
\ansExplain{18}{Find $k$: $8 \div 5 = 1.6$. Check: $24 \div 15 = 1.6$ \checkmark . Missing value: $y = 1.6 \times 10 = 16$.}
\ansItem{19}{$x = 12$}
\ansExplain{19}{Find $k$: $5 \div 2 = 2.5$. Check: $15 \div 6 = 2.5$ \checkmark . Missing value: $x = 30 \div 2.5 = 12$.}
\ansItem{20}{No}
\ansExplain{20}{Relationship A: $k = 6 \div 2 = 3$ (check: $18 \div 6 = 3$ \checkmark ). Relationship B: $k = 12 \div 3 = 4$ (but $18 \div 6 = 3 \neq 4$). B is not actually proportional through both given points or they belong to different lines. A has $k = 3$ and B has $k = 4$, so they are different.}
\ansItem{21}{$y = 15$; $x = 32$}
\ansExplain{21}{When $x = 20$: $y = \frac {3}{4} \times 20 = 15$. When $y = 24$: $x = 24 \div \frac {3}{4} = 24 \times \frac {4}{3} = 32$.}
\ansSec{1.4}
\ansItem{1}{$c = 0.60n$}
\ansExplain{1}{The rate is $\$0.60$ per banana, so $k = 0.60$ and the equation is $c = 0.60n$.}
\ansItem{2}{$d = 55t$}
\ansExplain{2}{The rate is $55$ miles per hour, so $k = 55$ and the equation is $d = 55t$, where $t$ is time in hours.}
\ansItem{3}{$w = 3h$}
\ansExplain{3}{The rate is $3$ walls per hour, so $k = 3$ and the equation is $w = 3h$.}
\ansItem{4}{$t = 120d$}
\ansExplain{4}{The production rate is $120$ toys per day, so $k = 120$ and the equation is $t = 120d$.}
\ansItem{5}{$c = 15m$}
\ansExplain{5}{The rate is $\$15$ per month with no extra fees, so $k = 15$ and the equation is $c = 15m$.}
\ansItem{6}{$y = 4.5x$; $y = 45$}
\ansExplain{6}{Find $k$: $9 \div 2 = 4.5$. Equation: $y = 4.5x$. When $x = 10$: $y = 4.5 \times 10 = 45$.}
\ansItem{7}{$c = 3.50p$; $\$24.50$}
\ansExplain{7}{Find $k$: $10.50 \div 3 = 3.50$. Equation: $c = 3.50p$. For $7$ pounds: $c = 3.50 \times 7 = \$24.50$.}
\ansItem{8}{$y = 1.5x$; $x = 20$}
\ansExplain{8}{Find $k$: $6 \div 4 = 1.5$. Equation: $y = 1.5x$. When $y = 30$: $30 = 1.5x$, so $x = 30 \div 1.5 = 20$.}
\ansItem{9}{$p = 8m$; $25$ minutes}
\ansExplain{9}{Find $k$: $40 \div 5 = 8$ pages per minute. Equation: $p = 8m$. For $200$ pages: $200 = 8m$, so $m = 200 \div 8 = 25$ minutes.}
\ansItem{10}{$27$ miles}
\ansExplain{10}{Substitute $t = 6$: $d = 4.5 \times 6 = 27$ miles.}
\ansItem{11}{$62.5$ grams}
\ansExplain{11}{Set $c = 5$: $5 = 0.08w$, so $w = 5 \div 0.08 = 62.5$ grams.}
\ansItem{12}{$15$ hours}
\ansExplain{12}{Set $p = 180$: $180 = 12h$, so $h = 180 \div 12 = 15$ hours.}
\ansItem{13}{$m = \frac {2}{3}s$; $6$ cups}
\ansExplain{13}{The rate is $\frac {2}{3}$ cup per serving, so $m = \frac {2}{3}s$. For $9$ servings: $m = \frac {2}{3} \times 9 = 6$ cups.}
\ansItem{14}{$w = 2.5t$; $32$ minutes}
\ansExplain{14}{The equation is $w = 2.5t$. Set $w = 80$: $80 = 2.5t$, so $t = 80 \div 2.5 = 32$ minutes.}
\ansItem{15}{A}
\ansExplain{15}{The price is $\$6$ per pound with no extra fee. A proportional equation is $y = kx$, so $c = 6p$. Choice B adds $6$ instead of multiplying. Choice C divides incorrectly. Choice D reverses the variables.}
\ansItem{16}{C}
\ansExplain{16}{Find $k$: $20 \div 5 = 4$, so $y = 4x$. Choice A uses $k = 5$ (wrong). Choice B uses $k = 20$ (wrong). Choice D is not proportional because of the $+15$.}
\ansItem{17}{C}
\ansExplain{17}{A proportional equation has the form $y = kx$ with no added constant. Equation $y = 2x + 1$ has a $+1$, so it is not proportional. The other three are all $y = kx$.}
\ansItem{18}{$c = 9h$; $\$31.50$}
\ansExplain{18}{The rate is $\$9$ per hour, so $c = 9h$. For $3.5$ hours: $c = 9 \times 3.5 = \$31.50$.}
\ansItem{19}{$d = 65h$; $325$ miles}
\ansExplain{19}{Find $k$: $195 \div 3 = 65$ mph. Equation: $d = 65h$. For $5$ hours: $d = 65 \times 5 = 325$ miles.}
\ansItem{20}{$5$ pounds}
\ansExplain{20}{Equation: $c = 2.80p$. Set $c = 14$: $14 = 2.80p$, so $p = 14 \div 2.80 = 5$ pounds.}
\ansItem{21}{$x = 12$}
\ansExplain{21}{Set up the equation: $4x = 3.5x + 6$. Subtract $3.5x$: $0.5x = 6$. Divide: $x = 12$.}
\ansItem{22}{$k = 7.5$; $y = 30$}
\ansExplain{22}{Find $k$: $5 \div \frac {2}{3} = 5 \times \frac {3}{2} = \frac {15}{2} = 7.5$. When $x = 4$: $y = 7.5 \times 4 = 30$.}
\ansSec{1.5}
\ansItem{1}{$k = 5$}
\ansExplain{1}{Divide $y$ by $x$: $10 \div 2 = 5$.}
\ansItem{2}{$k = 4.5$}
\ansExplain{2}{Divide $y$ by $x$: $18 \div 4 = 4.5$.}
\ansItem{3}{$k = 7$}
\ansExplain{3}{Divide $y$ by $x$: $35 \div 5 = 7$.}
\ansItem{4}{$k = 2.5$}
\ansExplain{4}{Divide $y$ by $x$: $7.5 \div 3 = 2.5$.}
\ansItem{5}{$k = 6$}
\ansExplain{5}{When $x = 1$, the $y$-value is the unit rate: $k = 6$.}
\ansItem{6}{$k = 2.5$}
\ansExplain{6}{Divide $y$ by $x$: $20 \div 8 = 2.5$.}
\ansItem{7}{One movie ticket costs $\$8$}
\ansExplain{7}{The point $(1, r)$ gives the unit rate. Here $x = 1$ ticket and $y = \$8$, so one ticket costs $\$8$.}
\ansItem{8}{$(0,0)$: no time means no distance; speed $= 45$ mi/hr}
\ansExplain{8}{The origin means $0$ hours traveled gives $0$ miles. The speed (unit rate) is $90 \div 2 = 45$ miles per hour.}
\ansItem{9}{$(1, 1.5)$}
\ansExplain{9}{Find $k$: $6 \div 4 = 1.5$. At $x = 1$, $y = 1.5$, so the point is $(1, 1.5)$.}
\ansItem{10}{Graph A}
\ansExplain{10}{Graph A: $k = 15 \div 3 = 5$. Graph B: $k = 9 \div 3 = 3$. A higher $k$ means a steeper line, so Graph A is steeper.}
\ansItem{11}{Store B charges $\$0.75$ more per item}
\ansExplain{11}{Store A: $k = 3.50$. Store B: $k = 4.25$. Store B charges more per item. Difference: $4.25 - 3.50 = \$0.75$.}
\ansItem{12}{Runner A}
\ansExplain{12}{Runner A: $k = 12 \div 2 = 6$ units/time. Runner B: $k = 15 \div 3 = 5$. Since $6 > 5$, Runner A is faster.}
\ansItem{13}{$10$ days}
\ansExplain{13}{Difference per day: $2 - 1.5 = 0.5$ cm. To reach $5$ cm difference: $5 \div 0.5 = 10$ days.}
\ansItem{14}{$12$ miles}
\ansExplain{14}{Dani: $12 \times 3 = 36$ miles. Kim: $8 \times 3 = 24$ miles. Difference: $36 - 24 = 12$ miles apart.}
\ansItem{15}{True}
\ansExplain{15}{By definition, $y = kx$ evaluated at $x = 1$ gives $y = k$. So the $y$-coordinate at $x = 1$ is the unit rate $k$.}
\ansItem{16}{False}
\ansExplain{16}{Steeper means a larger unit rate. A line with $k = 5$ is steeper than a line with $k = 2$ because $y$ grows faster per unit of $x$.}
\ansItem{17}{True}
\ansExplain{17}{Both lines pass through $(0, 0)$ (proportional) and $(4, 20)$. Two points determine a unique line, so they are the same line with $k = 5$.}
\ansItem{18}{False}
\ansExplain{18}{A proportional relationship always passes through the origin. If the $y$-intercept is anything other than $0$, the relationship is not proportional.}
\ansItem{19}{$(0,0),\; (1,6),\; (2,12),\; (3,18)$}
\ansExplain{19}{Substitute: $6(0)=0$, $6(1)=6$, $6(2)=12$, $6(3)=18$. The four points are $(0,0)$, $(1,6)$, $(2,12)$, $(3,18)$.}
\ansItem{20}{$y = 2.5x$; $y = 20$}
\ansExplain{20}{Find $k$: $12.5 \div 5 = 2.5$. Equation: $y = 2.5x$. When $x = 8$: $y = 2.5 \times 8 = 20$.}
\ansItem{21}{$x = 14$}
\ansExplain{21}{Find $k$: $14 \div 4 = 3.5$. Set $49 = 3.5x$: $x = 49 \div 3.5 = 14$.}
\ansItem{22}{Line A is steeper; $x = 9$}
\ansExplain{22}{Line A: $k = 5 \div 2 = 2.5$. Line B: $k = 5 \div 3 \approx 1.67$. Since $2.5 > 1.67$, Line A is steeper. For Line B when $y = 15$: $15 = \frac {5}{3}x$, so $x = 15 \times \frac {3}{5} = 9$.}
\ansItem{23}{Slope $= 6$; $y = 27$}
\ansExplain{23}{Find $k$: $3 \div \frac {1}{2} = 3 \times 2 = 6$. The slope is $6$. When $x = 4.5$: $y = 6 \times 4.5 = 27$.}
\ansSec{1.6}
\ansItem{1}{$\$2.50$}
\ansExplain{1}{Divide total by quantity: $10 \div 4 = \$2.50$ per notebook.}
\ansItem{2}{$30$ miles}
\ansExplain{2}{Divide distance by gallons: $180 \div 6 = 30$ miles per gallon.}
\ansItem{3}{$9$ eggs}
\ansExplain{3}{Scale factor: $6 \div 2 = 3$. Multiply eggs: $3 \times 3 = 9$ eggs.}
\ansItem{4}{$40$ km}
\ansExplain{4}{Multiply by the scale: $8 \times 5 = 40$ km.}
\ansItem{5}{$\$0.75$}
\ansExplain{5}{Divide to find the unit price: $9 \div 12 = \$0.75$ per muffin.}
\ansItem{6}{$675$ bottles}
\ansExplain{6}{Unit rate: $360 \div 8 = 45$ bottles per hour. In $15$ hours: $45 \times 15 = 675$ bottles.}
\ansItem{7}{$70$ km}
\ansExplain{7}{Unit rate: $42 \div 3 = 14$ km per hour. In $5$ hours: $14 \times 5 = 70$ km.}
\ansItem{8}{$\$14$}
\ansExplain{8}{Unit rate: $8.40 \div 6 = \$1.40$ per pound. For $10$ pounds: $1.40 \times 10 = \$14$.}
\ansItem{9}{$20$ minutes}
\ansExplain{9}{Unit rate: $90 \div 6 = 15$ pages per minute. Time: $300 \div 15 = 20$ minutes.}
\ansItem{10}{$35$ km}
\ansExplain{10}{Proportion: $\frac {3}{21} = \frac {5}{d}$. Cross-multiply: $3d = 105$, so $d = 35$ km.}
\ansItem{11}{$30$ feet}
\ansExplain{11}{Proportion: $\frac {6}{4} = \frac {h}{20}$. Cross-multiply: $4h = 120$, so $h = 30$ feet.}
\ansItem{12}{$\$90$}
\ansExplain{12}{Proportion: $\frac {7}{52.50} = \frac {12}{c}$. Cross-multiply: $7c = 630$, so $c = \$90$.}
\ansItem{13}{$12.5$ cups}
\ansExplain{13}{Proportion: $\frac {8}{5} = \frac {20}{f}$. Cross-multiply: $8f = 100$, so $f = 12.5$ cups.}
\ansItem{14}{Brand B ($\$0.85$/bar $<$ $\$0.90$/bar)}
\ansExplain{14}{Brand A: $4.50 \div 5 = \$0.90$ per bar. Brand B: $6.80 \div 8 = \$0.85$ per bar. Brand B is cheaper per bar.}
\ansItem{15}{Large ($\$2.20$/L $<$ $\$2.40$/L)}
\ansExplain{15}{Small: $1.80 \div 0.75 = \$2.40$ per liter. Large: $3.30 \div 1.5 = \$2.20$ per liter. The large bottle is the better deal.}
\ansItem{16}{Pack B ($\$0.23$/pencil $<$ $\$0.25$/pencil)}
\ansExplain{16}{Pack A: $3.75 \div 15 = \$0.25$ per pencil. Pack B: $5.52 \div 24 = \$0.23$ per pencil. Pack B costs less per pencil.}
\ansItem{17}{$5\frac {1}{4}$ cups of rice and $7$ cups of beans}
\ansExplain{17}{Scale factor: $14 \div 4 = 3.5$. Rice: $\frac {3}{2} \times 3.5 = \frac {3}{2} \times \frac {7}{2} = \frac {21}{4} = 5\frac {1}{4}$ cups. Beans: $2 \times 3.5 = 7$ cups.}
\ansItem{18}{$\$70$}
\ansExplain{18}{Miles per gallon: $280 \div 8 = 35$. Gallons for $700$ miles: $700 \div 35 = 20$. Cost: $20 \times 3.50 = \$70$.}
\ansItem{19}{$5\frac {5}{8}$ hours}
\ansExplain{19}{Actual distance: $\frac {9}{2} \times 15 = \frac {135}{2} = 67.5$ miles. Time: $67.5 \div 12 = 5.625 = 5\frac {5}{8}$ hours.}
\ansItem{20}{$2$ large cans for $\$110$}
\ansExplain{20}{Unit prices: Small $= 18 \div 0.75 = \$24$/gal. Large $= 55 \div 2.5 = \$22$/gal. The large can is cheaper per gallon. Two large cans give $2 \times 2.5 = 5$ gallons exactly, costing $2 \times 55 = \$110$.}
\ansItem{21}{Train is $300$ m; speed $= 30$ m/s}
\ansExplain{21}{The train covers its own length plus the bridge. Set up: $(L + 300)/20 = (L + 450)/25$. Cross-multiply: $25(L + 300) = 20(L + 450)$, giving $25L + 7500 = 20L + 9000$, so $5L = 1500$ and $L = 300$ m. Speed $= (300 + 300)/20 = 600/20 = 30$ m/s.}
